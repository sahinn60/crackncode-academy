<!DOCTYPE html>
<html lang="bn" class="scroll-smooth">
<head>
  <%- include('partials/head') %>
</head>
<body class="min-h-screen bg-night font-display text-slate-200 antialiased">
  <%- include('partials/navbar') %>

  <main>
    <!-- Hero -->
    <section id="home" class="relative overflow-hidden border-b border-white/5">
      <div class="pointer-events-none absolute inset-0 bg-[radial-gradient(ellipse_80%_50%_at_50%_-20%,rgba(0,162,255,0.25),transparent)]"></div>
      <div class="relative mx-auto grid max-w-7xl gap-10 px-4 py-14 md:grid-cols-2 md:px-6 lg:py-20">
        <div class="flex flex-col justify-center">
          <div class="mb-4 inline-flex w-fit items-center gap-2 rounded-full border border-sky/30 bg-sky/10 px-3 py-1 text-sm text-sky">
            <span class="rounded-full bg-sky px-2 py-0.5 text-xs font-bold text-night">Trending</span>
            <span class="text-slate-200">ফ্রেশার থেকে কিংবা প্রফেশনাল</span>
          </div>
          <h1 class="mb-4 text-3xl font-bold leading-tight text-sky md:text-4xl lg:text-5xl">১৪৩৩ বৈশাখী অফার!</h1>
          <p class="mb-8 max-w-xl text-lg text-slate-300">
            CrackNcode Academy-তে AI, ডিজাইন, ভিডিও এডিটিং ও ফ্রিল্যান্সিং — সব মিলিয়ে স্মার্ট বান্ডেল। আজই শুরু করুন আপনার নতুন ক্যারিয়ার।
          </p>
          <div class="flex flex-wrap gap-3">
            <a href="/courses" class="inline-flex items-center justify-center rounded-xl bg-sky px-8 py-3.5 text-base font-semibold text-night shadow-lg shadow-sky/30 transition hover:bg-sky/90">বিস্তারিত দেখুন</a>
            <a href="/bundles" class="inline-flex items-center justify-center rounded-xl border border-white/20 bg-white/5 px-6 py-3.5 text-base font-medium text-white backdrop-blur transition hover:bg-white/10">২৮ টি রিসোর্স সুপার বান্ডেল!</a>
          </div>
        </div>
        <div class="flex items-center justify-center">
          <div class="relative w-full max-w-md rounded-3xl bg-[#f0f0f0] p-6 text-night shadow-2xl ring-1 ring-black/5">
            <span class="mb-3 inline-block rounded-md bg-red-500 px-2 py-0.5 text-xs font-bold text-white">Limited</span>
            <p class="text-xl font-bold leading-snug text-night md:text-2xl">নতুন ক্যারিয়ার শুরু করুন — প্রমো ভিডিও দেখুন</p>
            <div class="relative my-8 flex justify-center">
              <button type="button" class="flex h-20 w-20 items-center justify-center rounded-full bg-emerald-500 text-white shadow-lg shadow-emerald-600/40 ring-4 ring-white" aria-label="Play video">
                <svg class="ml-1 h-9 w-9" fill="currentColor" viewBox="0 0 24 24"><path d="M8 5v14l11-7z"/></svg>
              </button>
            </div>
            <button type="button" class="w-full rounded-xl bg-red-500 py-3 text-sm font-semibold text-white transition hover:bg-red-600">অফার দেখুন</button>
            <div class="mt-6 flex justify-center gap-2">
              <% for (let i = 0; i < 4; i++) { %>
                <span class="h-10 w-10 rounded-lg bg-amber-800/80 ring-2 ring-amber-600/50"></span>
              <% } %>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- Top selling -->
    <section class="border-b border-white/5 py-16 md:py-20">
      <div class="mx-auto max-w-7xl px-4 md:px-6">
        <div class="mb-10 text-center">
          <h2 class="text-3xl font-bold text-white md:text-4xl">টপ সেলিং কোর্স</h2>
          <p class="mt-2 text-slate-400">যে কোর্সগুলো শিক্ষার্থীরা সবচেয়ে বেশি পছন্দ করছে</p>
        </div>
        <div class="grid gap-6 lg:grid-cols-2">
          <a href="/courses/<%= topSelling.featured.slug %>" class="overflow-hidden rounded-2xl border border-white/10 bg-gradient-to-br from-[#0a1f3d] to-card shadow-xl transition hover:border-sky/40 lg:flex">
            <div class="relative h-56 shrink-0 lg:h-auto lg:w-1/2">
              <img src="<%= topSelling.featured.image %>" alt="" class="h-full w-full object-cover" loading="lazy" width="800" height="420" />
            </div>
            <div class="flex flex-1 flex-col justify-center p-6 md:p-8">
              <span class="mb-2 w-fit rounded bg-red-500/90 px-2 py-0.5 text-xs font-semibold text-white"><%= topSelling.featured.badge %></span>
              <h3 class="text-xl font-bold text-white md:text-2xl"><%= topSelling.featured.title %></h3>
              <p class="mt-2 text-sm text-slate-400"><%= topSelling.featured.desc %></p>
              <div class="mt-4 flex items-baseline gap-3">
                <span class="text-2xl font-bold text-fire">৳<%= topSelling.featured.price.toLocaleString("bn-BD") %></span>
                <span class="text-sm text-slate-500 line-through">৳<%= topSelling.featured.oldPrice.toLocaleString("bn-BD") %></span>
              </div>
            </div>
          </a>
          <div class="flex flex-col gap-4">
            <% topSelling.side.forEach(function (c) { %>
              <a href="/courses/<%= c.slug %>" class="flex overflow-hidden rounded-2xl border border-white/10 bg-card transition hover:border-sky/30">
                <img src="<%= c.image %>" alt="" class="h-28 w-32 shrink-0 object-cover sm:h-32 sm:w-40" loading="lazy" width="280" height="200" />
                <div class="flex min-w-0 flex-1 flex-col justify-center p-4">
                  <h3 class="line-clamp-2 text-sm font-semibold text-white md:text-base"><%= c.title %></h3>
                  <div class="mt-2 flex flex-wrap items-baseline gap-2">
                    <span class="text-lg font-bold text-fire">৳<%= c.price.toLocaleString("bn-BD") %></span>
                    <% if (c.oldPrice) { %>
                      <span class="text-xs text-slate-500 line-through">৳<%= c.oldPrice.toLocaleString("bn-BD") %></span>
                    <% } %>
                  </div>
                </div>
              </a>
            <% }); %>
          </div>
        </div>
      </div>
    </section>

    <!-- Featured courses -->
    <section id="courses" class="border-b border-white/5 py-16 md:py-20">
      <div class="mx-auto max-w-7xl px-4 md:px-6">
        <div class="mb-4 flex justify-center">
          <a href="/courses" class="rounded-full border border-sky/40 bg-sky/10 px-4 py-1.5 text-sm text-sky transition hover:bg-sky/20">আরও দেখুন →</a>
        </div>
        <div class="mb-10 text-center">
          <h2 class="text-3xl font-bold text-white md:text-4xl">ফিচার্ড কোর্স</h2>
          <p class="mt-2 text-slate-400">হাতে-কলমে প্রজেক্ট ও আপডেটেড কারিকুলাম</p>
        </div>
        <div class="grid gap-6 sm:grid-cols-2 xl:grid-cols-4">
          <% featuredCourses.forEach(function (c) { %>
            <article class="flex flex-col overflow-hidden rounded-2xl border border-white/10 bg-card shadow-lg transition hover:border-sky/40 hover:shadow-sky/5">
              <a href="/courses/<%= c.slug %>" class="aspect-[16/10] block overflow-hidden">
                <img src="<%= c.image %>" alt="" class="h-full w-full object-cover transition duration-500 hover:scale-105" loading="lazy" width="640" height="400" />
              </a>
              <div class="flex flex-1 flex-col p-5">
                <a href="/courses/<%= c.slug %>" class="text-lg font-bold text-white hover:text-sky"><%= c.titleBn %></a>
                <p class="mt-2 line-clamp-2 flex-1 text-sm text-slate-400"><%= c.desc %></p>
                <div class="mt-4 flex items-baseline gap-2">
                  <span class="text-xl font-bold text-fire">৳<%= c.price.toLocaleString("bn-BD") %></span>
                  <span class="text-sm text-slate-500 line-through">৳<%= c.oldPrice.toLocaleString("bn-BD") %></span>
                </div>
                <div class="mt-4 grid grid-cols-2 gap-2">
                  <form action="/cart/add" method="post" class="contents" data-ajax-cart>
                    <input type="hidden" name="type" value="course" />
                    <input type="hidden" name="slug" value="<%= c.slug %>" />
                    <input type="hidden" name="redirect" value="/" />
                    <button type="submit" class="flex w-full items-center justify-center gap-1 rounded-xl border border-sky/50 bg-night/50 py-2.5 text-sm font-medium text-sky transition hover:bg-sky/10">
                    <svg class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 3h2l.4 2M7 13h10l4-8H5.4M7 13L5.4 5M7 13l-2.293 2.293c-.63.63-.184 1.707.707 1.707H17m0 0a2 2 0 100 4 2 2 0 000-4zm-8 2a2 2 0 11-4 0 2 2 0 014 0z"/></svg>
                    কার্ট
                  </button>
                  </form>
                  <a href="/courses/<%= c.slug %>" class="flex items-center justify-center gap-1 rounded-xl border border-white/15 bg-white/5 py-2.5 text-sm font-medium text-white transition hover:bg-white/10">
                    বিস্তারিত
                    <svg class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg>
                  </a>
                </div>
                <div class="mt-3 flex items-center justify-end gap-1 text-xs text-slate-500">
                  <svg class="h-3.5 w-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
                  <%= c.duration %>
                </div>
              </div>
            </article>
          <% }); %>
        </div>
      </div>
    </section>

    <!-- E-books -->
    <section id="ebooks" class="border-b border-white/5 py-16 md:py-20">
      <div class="mx-auto max-w-7xl px-4 md:px-6">
        <div class="mb-4 flex justify-center">
          <a href="/ebooks" class="inline-block rounded-full bg-sky px-5 py-2 text-sm font-semibold text-night shadow-lg shadow-sky/25">আরও দেখুন</a>
        </div>
        <div class="mb-10 text-center">
          <h2 class="text-3xl font-bold text-white md:text-4xl">ফিচার্ড ই-বুক</h2>
          <p class="mt-2 text-slate-400">পিডিএফ, চেকলিস্ট ও টেমপ্লেট — ডাউনলোড করে শিখুন</p>
        </div>
        <div class="grid gap-6 sm:grid-cols-2 md:grid-cols-3 lg:grid-cols-5">
          <% ebooks.forEach(function (b) { %>
            <article class="overflow-hidden rounded-2xl border border-white/10 bg-card p-3 transition hover:border-sky/35">
              <a href="/ebooks" class="block overflow-hidden rounded-xl ring-1 ring-white/10">
                <img src="<%= b.cover %>" alt="" class="aspect-[3/4] w-full object-cover" loading="lazy" width="400" height="520" />
              </a>
              <h3 class="mt-3 line-clamp-2 text-sm font-semibold text-white"><%= b.title %></h3>
              <p class="text-xs text-sky/90">By <%= b.author %></p>
              <div class="mt-3 flex items-center justify-between gap-2">
                <div>
                  <span class="text-lg font-bold text-fire">৳<%= b.price %></span>
                  <span class="ml-1 text-xs text-slate-500 line-through">৳<%= b.old %></span>
                </div>
                <form action="/cart/add" method="post" class="inline" data-ajax-cart>
                  <input type="hidden" name="type" value="ebook" />
                  <input type="hidden" name="slug" value="<%= b.slug %>" />
                  <input type="hidden" name="redirect" value="/" />
                  <button type="submit" class="flex shrink-0 items-center gap-1 rounded-lg border border-sky/40 bg-night/40 px-2 py-1.5 text-xs text-sky hover:bg-sky/10">
                  <svg class="h-3.5 w-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"/><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z"/></svg>
                  কার্ট
                </button>
                </form>
              </div>
            </article>
          <% }); %>
        </div>
      </div>
    </section>

    <!-- Bundles -->
    <section id="bundles" class="border-b border-white/5 py-16 md:py-20">
      <div class="mx-auto max-w-7xl px-4 md:px-6">
        <div class="mb-4 flex justify-center">
          <a href="/bundles" class="inline-flex items-center gap-1 rounded-full border border-sky/30 bg-sky/10 px-4 py-1.5 text-sm text-sky transition hover:bg-sky/20">আরও দেখুন <svg class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg></a>
        </div>
        <div class="mb-10 text-center">
          <h2 class="text-3xl font-bold text-white md:text-4xl">ফিচার্ড বান্ডেল</h2>
          <p class="mt-2 text-slate-400">একসাথে কিনুন, বেশি সাশ্রয় করুন</p>
        </div>
        <div class="grid gap-6 sm:grid-cols-2 lg:grid-cols-4">
          <% bundles.forEach(function (b) { %>
            <article class="overflow-hidden rounded-2xl border border-amber-500/20 bg-card shadow-lg">
              <a href="/bundles" class="relative block aspect-video overflow-hidden ring-2 ring-amber-400/30">
                <img src="<%= b.image %>" alt="" class="h-full w-full object-cover" loading="lazy" width="640" height="360" />
              </a>
              <div class="p-5">
                <h3 class="font-bold text-white"><%= b.title %></h3>
                <div class="mt-3 flex items-baseline gap-2">
                  <span class="text-xl font-bold text-fire">৳<%= b.price.toLocaleString("bn-BD") %></span>
                  <span class="text-sm text-slate-500 line-through">৳<%= b.old.toLocaleString("bn-BD") %></span>
                </div>
                <div class="mt-4 grid grid-cols-2 gap-2">
                  <form action="/cart/add" method="post" class="contents" data-ajax-cart>
                    <input type="hidden" name="type" value="bundle" />
                    <input type="hidden" name="slug" value="<%= b.id %>" />
                    <input type="hidden" name="redirect" value="/" />
                    <button type="submit" class="flex w-full items-center justify-center gap-1 rounded-xl border border-white/10 bg-night/60 py-2.5 text-sm text-white hover:bg-white/10">
                    <svg class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 3h2l.4 2M7 13h10l4-8H5.4"/></svg>
                    কার্ট
                  </button>
                  </form>
                  <a href="/bundles" class="flex items-center justify-center gap-1 rounded-xl bg-sky/90 py-2.5 text-sm font-medium text-night hover:bg-sky">
                    <svg class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"/></svg>
                    ডিটেইলস
                  </a>
                </div>
              </div>
            </article>
          <% }); %>
        </div>
        <div class="mt-10 flex justify-center">
          <a href="/bundles" class="inline-block rounded-full bg-sky px-6 py-2.5 text-sm font-semibold text-night">আরও দেখুন</a>
        </div>
      </div>
    </section>

    <!-- Workshops placeholder -->
    <section id="workshops" class="border-b border-white/5 py-12">
      <div class="mx-auto max-w-3xl px-4 text-center md:px-6">
        <h2 class="text-2xl font-bold text-white">লাইভ ওয়ার্কশপ</h2>
        <p class="mt-2 text-slate-400">লাইভ ও প্রি-রেকর্ডেড ওয়ার্কশপ — তালিকা দেখুন।</p>
        <a id="signup" href="/workshops" class="mt-4 inline-flex rounded-full border border-white/20 px-6 py-2 text-sm text-sky hover:bg-white/5">সব ওয়ার্কশপ</a>
        <a href="/login" class="mt-4 inline-flex rounded-full bg-fire px-8 py-3 font-semibold text-white">সাইন আপ / লগইন</a>
      </div>
    </section>

    <!-- Testimonials -->
    <section class="py-16 md:py-20">
      <div class="mx-auto max-w-7xl px-4 md:px-6">
        <div class="mb-4 flex justify-center">
          <span class="rounded-full bg-sky px-5 py-2 text-sm font-medium text-night">আরও দেখুন →</span>
        </div>
        <div class="mb-10 text-center">
          <h2 class="text-3xl font-bold text-white md:text-4xl">শিক্ষার্থীদের মতামত</h2>
          <p class="mt-2 text-slate-300">আমাদের শিক্ষার্থীরা যা বলছে</p>
        </div>
        <div class="grid gap-5 sm:grid-cols-2 lg:grid-cols-4">
          <% testimonials.forEach(function (t) { %>
            <article class="flex flex-col rounded-2xl border border-sky/20 bg-line/40 p-5 shadow-md backdrop-blur-sm">
              <div class="mb-3 flex items-start justify-between gap-2">
                <div class="flex items-center gap-3">
                  <span class="flex h-11 w-11 items-center justify-center rounded-full bg-sky text-sm font-bold text-night"><%= t.initials %></span>
                  <div>
                    <p class="font-semibold text-white"><%= t.name %></p>
                    <div class="mt-0.5 flex" aria-label="<%= t.rating %> stars">
                      <% for (let s = 1; s <= 5; s++) { %>
                        <span class="<%= s <= t.rating ? 'text-amber-400' : 'text-slate-600' %>">★</span>
                      <% } %>
                    </div>
                  </div>
                </div>
                <time class="shrink-0 text-xs text-slate-500"><%= t.date %></time>
              </div>
              <p class="flex-1 text-sm leading-relaxed text-slate-200"><%= t.text %></p>
              <div class="mt-4 border-t border-white/10 pt-3 text-xs text-sky"><%= t.course %></div>
            </article>
          <% }); %>
        </div>
      </div>
    </section>
  </main>

  <%- include('partials/footer') %>

  <button type="button" id="toTop" class="fixed bottom-6 right-6 z-50 flex h-12 w-12 items-center justify-center rounded-full bg-sky text-night shadow-lg shadow-sky/40 opacity-0 pointer-events-none transition-opacity" aria-label="উপরে যান">
    <svg class="h-5 w-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 10l7-7m0 0l7 7m-7-7v18"/></svg>
  </button>

  <%- include('partials/scripts') %>
</body>
</html>

<!DOCTYPE html>
<html lang="en" class="scroll-smooth">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title><%= pageTitle %> — CrackNcode Admin</title>
  <script src="https://cdn.tailwindcss.com"></script>
  <script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.0/dist/chart.umd.min.js"></script>
  <script>tailwind.config={theme:{extend:{colors:{night:"#000b1a",card:"#0a1428",sky:"#00a2ff",fire:"#ff6600"}}}}</script>
</head>
<body class="min-h-screen bg-[#000b1a] text-slate-200 flex">

  <!-- Sidebar -->
  <aside id="sidebar" class="fixed inset-y-0 left-0 z-40 flex w-60 flex-col border-r border-white/10 bg-[#0a1428] transition-transform duration-200 lg:translate-x-0 -translate-x-full">
    <div class="flex h-16 items-center gap-2 border-b border-white/10 px-5">
      <div class="flex h-8 w-8 items-center justify-center rounded-lg bg-gradient-to-br from-[#00a2ff] to-[#ff6600] text-xs font-bold text-white">CN</div>
      <span class="font-bold text-white">Admin Panel</span>
    </div>
    <nav class="flex-1 overflow-y-auto px-3 py-4 space-y-1">
      <a href="/admin" class="flex items-center gap-3 rounded-xl px-3 py-2.5 text-sm bg-[#00a2ff]/20 text-[#00a2ff] font-semibold">
        <svg class="h-4 w-4 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6"/></svg>
        Dashboard
      </a>
      <a href="/admin/courses" class="flex items-center gap-3 rounded-xl px-3 py-2.5 text-sm text-slate-300 hover:bg-white/5 hover:text-white">
        <svg class="h-4 w-4 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6.253v13m0-13C10.832 5.477 9.246 5 7.5 5S4.168 5.477 3 6.253v13C4.168 18.477 5.754 18 7.5 18s3.332.477 4.5 1.253m0-13C13.168 5.477 14.754 5 16.5 5c1.747 0 3.332.477 4.5 1.253v13C19.832 18.477 18.247 18 16.5 18c-1.746 0-3.332.477-4.5 1.253"/></svg>
        Courses
      </a>
      <a href="/admin/bundles" class="flex items-center gap-3 rounded-xl px-3 py-2.5 text-sm text-slate-300 hover:bg-white/5 hover:text-white">
        <svg class="h-4 w-4 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M20 7l-8-4-8 4m16 0l-8 4m8-4v10l-8 4m0-10L4 7m8 4v10M4 7v10l8 4"/></svg>
        Bundles
      </a>
      <a href="/admin/workshops" class="flex items-center gap-3 rounded-xl px-3 py-2.5 text-sm text-slate-300 hover:bg-white/5 hover:text-white">
        <svg class="h-4 w-4 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 10l4.553-2.069A1 1 0 0121 8.87v6.26a1 1 0 01-1.447.894L15 14M3 8h12v8H3z"/></svg>
        Workshops
      </a>
      <a href="/admin/ebooks" class="flex items-center gap-3 rounded-xl px-3 py-2.5 text-sm text-slate-300 hover:bg-white/5 hover:text-white">
        <svg class="h-4 w-4 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6.253v13m0-13C10.832 5.477 9.246 5 7.5 5S4.168 5.477 3 6.253v13"/></svg>
        E-Books
      </a>
      <a href="/admin/blogs" class="flex items-center gap-3 rounded-xl px-3 py-2.5 text-sm text-slate-300 hover:bg-white/5 hover:text-white">
        <svg class="h-4 w-4 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z"/></svg>
        Blogs
      </a>
      <a href="/admin/users" class="flex items-center gap-3 rounded-xl px-3 py-2.5 text-sm text-slate-300 hover:bg-white/5 hover:text-white">
        <svg class="h-4 w-4 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0z"/></svg>
        Users
      </a>
      <a href="/admin/orders" class="flex items-center gap-3 rounded-xl px-3 py-2.5 text-sm text-slate-300 hover:bg-white/5 hover:text-white">
        <svg class="h-4 w-4 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2"/></svg>
        Orders
      </a>
      <a href="/admin/messages" class="flex items-center gap-3 rounded-xl px-3 py-2.5 text-sm text-slate-300 hover:bg-white/5 hover:text-white">
        <svg class="h-4 w-4 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/></svg>
        Messages
      </a>
    </nav>
    <div class="border-t border-white/10 p-3">
      <a href="/" class="flex items-center gap-3 rounded-xl px-3 py-2.5 text-sm text-slate-400 hover:bg-white/5 hover:text-white">
        <svg class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 19l-7-7m0 0l7-7m-7 7h18"/></svg>
        Back to Site
      </a>
      <form action="/logout" method="POST">
        <button type="submit" class="flex w-full items-center gap-3 rounded-xl px-3 py-2.5 text-sm text-red-400 hover:bg-red-500/10">
          <svg class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 16l4-4m0 0l-4-4m4 4H7m6 4v1a3 3 0 01-3 3H6a3 3 0 01-3-3V7a3 3 0 013-3h4a3 3 0 013 3v1"/></svg>
          Logout
        </button>
      </form>
    </div>
  </aside>

  <!-- Main -->
  <div class="flex flex-1 flex-col lg:ml-60">
    <header class="sticky top-0 z-30 flex h-16 items-center justify-between border-b border-white/10 bg-[#000b1a]/95 px-4 backdrop-blur md:px-6">
      <button id="sidebarToggle" class="rounded-lg p-2 text-slate-400 hover:bg-white/5 lg:hidden">
        <svg class="h-5 w-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16"/></svg>
      </button>
      <h1 class="text-base font-semibold text-white">Dashboard</h1>
      <div class="flex items-center gap-2">
        <span class="flex h-8 w-8 items-center justify-center rounded-full bg-gradient-to-br from-[#00a2ff] to-[#ff6600] text-xs font-bold text-white">
          <%= authUser.name.slice(0,2).toUpperCase() %>
        </span>
        <span class="hidden text-sm text-slate-300 sm:block"><%= authUser.name %></span>
      </div>
    </header>

    <main class="flex-1 p-4 md:p-6">

      <!-- Stats cards -->
      <div class="grid gap-4 sm:grid-cols-2 xl:grid-cols-4">
        <div class="rounded-2xl border border-white/10 bg-[#0a1428] p-5">
          <p class="text-xs text-slate-400">Total Users</p>
          <p class="mt-1 text-3xl font-bold text-white"><%= stats.users %></p>
          <p class="mt-1 text-xs text-slate-500">Registered accounts</p>
        </div>
        <div class="rounded-2xl border border-white/10 bg-[#0a1428] p-5">
          <p class="text-xs text-slate-400">Total Courses</p>
          <p class="mt-1 text-3xl font-bold text-white"><%= stats.courses %></p>
          <p class="mt-1 text-xs text-slate-500">Published + drafts</p>
        </div>
        <div class="rounded-2xl border border-white/10 bg-[#0a1428] p-5">
          <p class="text-xs text-slate-400">Paid Orders</p>
          <p class="mt-1 text-3xl font-bold text-white"><%= stats.paidOrders %></p>
          <p class="mt-1 text-xs text-slate-500">Completed payments</p>
        </div>
        <div class="rounded-2xl border border-white/10 bg-[#0a1428] p-5">
          <p class="text-xs text-slate-400">Total Revenue</p>
          <p class="mt-1 text-3xl font-bold text-[#00a2ff]">৳ <%= stats.totalRevenue.toLocaleString() %></p>
          <p class="mt-1 text-xs text-slate-500">From paid orders</p>
        </div>
      </div>

      <!-- Charts row 1 -->
      <div class="mt-6 grid gap-6 lg:grid-cols-2">
        <div class="rounded-2xl border border-white/10 bg-[#0a1428] p-5">
          <h2 class="mb-4 font-semibold text-white">Revenue (Last 6 Months)</h2>
          <canvas id="revenueChart" height="200"></canvas>
        </div>
        <div class="rounded-2xl border border-white/10 bg-[#0a1428] p-5">
          <h2 class="mb-4 font-semibold text-white">Orders (Last 6 Months)</h2>
          <canvas id="ordersChart" height="200"></canvas>
        </div>
      </div>

      <!-- Charts row 2 -->
      <div class="mt-6 grid gap-6 lg:grid-cols-3">
        <div class="rounded-2xl border border-white/10 bg-[#0a1428] p-5">
          <h2 class="mb-4 font-semibold text-white">Orders by Status</h2>
          <canvas id="statusChart" height="220"></canvas>
        </div>
        <div class="rounded-2xl border border-white/10 bg-[#0a1428] p-5">
          <h2 class="mb-4 font-semibold text-white">Users by Role</h2>
          <canvas id="rolesChart" height="220"></canvas>
        </div>
        <div class="rounded-2xl border border-white/10 bg-[#0a1428] p-5">
          <h2 class="mb-4 font-semibold text-white">Products by Category</h2>
          <canvas id="productsChart" height="220"></canvas>
        </div>
      </div>

      <!-- Recent Orders & Recent Users side by side -->
      <div class="mt-6 grid gap-6 lg:grid-cols-2">

        <!-- Recent Orders -->
        <div class="rounded-2xl border border-white/10 bg-[#0a1428]">
          <div class="flex items-center justify-between border-b border-white/10 px-5 py-4">
            <h2 class="font-semibold text-white">Recent Orders</h2>
            <a href="/admin/orders" class="text-xs text-[#00a2ff] hover:underline">View all</a>
          </div>
          <div class="overflow-x-auto">
            <table class="w-full text-sm">
              <thead>
                <tr class="border-b border-white/10 text-xs text-slate-500">
                  <th class="px-4 py-3 text-left">User</th>
                  <th class="px-4 py-3 text-left">Total</th>
                  <th class="px-4 py-3 text-left">Status</th>
                  <th class="px-4 py-3 text-left">Date</th>
                </tr>
              </thead>
              <tbody>
                <% recentOrders.forEach(function(o) { %>
                <tr class="border-b border-white/5 hover:bg-white/5">
                  <td class="px-4 py-3 text-white"><%= o.user ? o.user.name : '—' %></td>
                  <td class="px-4 py-3 text-white">৳ <%= o.totalPrice.toLocaleString() %></td>
                  <td class="px-4 py-3">
                    <span class="rounded-full px-2 py-0.5 text-xs font-semibold
                      <%= o.status === 'PAID' ? 'bg-emerald-500/20 text-emerald-400' :
                          o.status === 'PENDING' ? 'bg-amber-500/20 text-amber-400' :
                          o.status === 'REFUNDED' ? 'bg-blue-500/20 text-blue-400' :
                          'bg-red-500/20 text-red-400' %>">
                      <%= o.status %>
                    </span>
                  </td>
                  <td class="px-4 py-3 text-slate-400 text-xs"><%= new Date(o.createdAt).toLocaleDateString('en-GB') %></td>
                </tr>
                <% }); %>
                <% if (recentOrders.length === 0) { %>
                <tr><td colspan="4" class="px-4 py-8 text-center text-slate-500">No orders yet.</td></tr>
                <% } %>
              </tbody>
            </table>
          </div>
        </div>

        <!-- Recent Users -->
        <div class="rounded-2xl border border-white/10 bg-[#0a1428]">
          <div class="flex items-center justify-between border-b border-white/10 px-5 py-4">
            <h2 class="font-semibold text-white">Recent Users</h2>
            <a href="/admin/users" class="text-xs text-[#00a2ff] hover:underline">View all</a>
          </div>
          <div class="overflow-x-auto">
            <table class="w-full text-sm">
              <thead>
                <tr class="border-b border-white/10 text-xs text-slate-500">
                  <th class="px-4 py-3 text-left">User</th>
                  <th class="px-4 py-3 text-left">Role</th>
                  <th class="px-4 py-3 text-left">Joined</th>
                </tr>
              </thead>
              <tbody>
                <% recentUsers.forEach(function(u) { %>
                <tr class="border-b border-white/5 hover:bg-white/5">
                  <td class="px-4 py-3">
                    <div class="flex items-center gap-2">
                      <span class="flex h-7 w-7 shrink-0 items-center justify-center rounded-full bg-gradient-to-br from-[#00a2ff] to-[#ff6600] text-xs font-bold text-white">
                        <%= u.name.slice(0,2).toUpperCase() %>
                      </span>
                      <div>
                        <p class="text-white text-xs font-medium"><%= u.name %></p>
                        <p class="text-slate-500 text-xs"><%= u.email %></p>
                      </div>
                    </div>
                  </td>
                  <td class="px-4 py-3">
                    <span class="rounded-full px-2 py-0.5 text-xs font-semibold <%= u.role === 'ADMIN' ? 'bg-cyan-500/20 text-cyan-400' : 'bg-blue-500/20 text-blue-400' %>">
                      <%= u.role %>
                    </span>
                  </td>
                  <td class="px-4 py-3 text-slate-400 text-xs"><%= new Date(u.createdAt).toLocaleDateString('en-GB') %></td>
                </tr>
                <% }); %>
                <% if (recentUsers.length === 0) { %>
                <tr><td colspan="3" class="px-4 py-8 text-center text-slate-500">No users yet.</td></tr>
                <% } %>
              </tbody>
            </table>
          </div>
        </div>

      </div>

    </main>
  </div>

  <script>
    // Sidebar toggle
    var toggle = document.getElementById("sidebarToggle");
    var sidebar = document.getElementById("sidebar");
    if (toggle) toggle.addEventListener("click", function() { sidebar.classList.toggle("-translate-x-full"); });
    document.addEventListener("click", function(e) {
      if (sidebar && !sidebar.contains(e.target) && toggle && !toggle.contains(e.target))
        sidebar.classList.add("-translate-x-full");
    });

    // Chart data from server
    var CD = <%- chartData %>;
    var grid = 'rgba(255,255,255,0.06)';
    var tick = '#94a3b8';
    var scaleOpts = { x: { ticks: { color: tick }, grid: { color: grid } }, y: { ticks: { color: tick }, grid: { color: grid } } };
    var legendOpts = { labels: { color: '#cbd5e1', font: { size: 12 } } };

    new Chart(document.getElementById('revenueChart'), {
      type: 'bar',
      data: { labels: CD.months, datasets: [{ label: 'Revenue (৳)', data: CD.revenue, backgroundColor: 'rgba(0,162,255,0.7)', borderRadius: 6 }] },
      options: { responsive: true, plugins: { legend: legendOpts }, scales: scaleOpts }
    });

    new Chart(document.getElementById('ordersChart'), {
      type: 'line',
      data: { labels: CD.months, datasets: [{ label: 'Orders', data: CD.orders, borderColor: '#ff6600', backgroundColor: 'rgba(255,102,0,0.15)', tension: 0.4, fill: true, pointBackgroundColor: '#ff6600' }] },
      options: { responsive: true, plugins: { legend: legendOpts }, scales: scaleOpts }
    });

    new Chart(document.getElementById('statusChart'), {
      type: 'doughnut',
      data: { labels: ['Paid','Pending','Failed','Refunded'], datasets: [{ data: [CD.orderStatus.PAID, CD.orderStatus.PENDING, CD.orderStatus.FAILED, CD.orderStatus.REFUNDED], backgroundColor: ['#10b981','#f59e0b','#ef4444','#3b82f6'], borderWidth: 0 }] },
      options: { responsive: true, cutout: '65%', plugins: { legend: legendOpts } }
    });

    new Chart(document.getElementById('rolesChart'), {
      type: 'pie',
      data: { labels: ['Users','Admins'], datasets: [{ data: [CD.userRoles.user, CD.userRoles.admin], backgroundColor: ['#00a2ff','#ff6600'], borderWidth: 0 }] },
      options: { responsive: true, plugins: { legend: legendOpts } }
    });

    new Chart(document.getElementById('productsChart'), {
      type: 'bar',
      data: { labels: ['Courses','Bundles','Workshops','E-Books'], datasets: [{ label: 'Count', data: [CD.products.courses, CD.products.bundles, CD.products.workshops, CD.products.ebooks], backgroundColor: ['#00a2ff','#f59e0b','#10b981','#8b5cf6'], borderRadius: 6 }] },
      options: { responsive: true, plugins: { legend: { display: false } }, scales: scaleOpts }
    });
  </script>
</body>
</html>

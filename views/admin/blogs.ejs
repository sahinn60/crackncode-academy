<%
var body = `
<div class="mb-5 flex items-center justify-between">
  <p class="text-sm text-slate-400">${items.length} blogs</p>
  <button onclick="document.getElementById('addModal').classList.remove('hidden')"
    class="rounded-xl bg-gradient-to-r from-cyan-500 to-blue-600 px-4 py-2 text-sm font-semibold text-white">+ Add Blog</button>
</div>

<div class="rounded-2xl border border-white/10 bg-[#0a1428] overflow-hidden">
  <div class="overflow-x-auto">
    <table class="w-full text-sm">
      <thead><tr class="border-b border-white/10 text-xs text-slate-500">
        <th class="px-5 py-3 text-left">Blog</th>
        <th class="px-5 py-3 text-left">Excerpt</th>
        <th class="px-5 py-3 text-left">Status</th>
        <th class="px-5 py-3 text-left">Date</th>
        <th class="px-5 py-3 text-left">Actions</th>
      </tr></thead>
      <tbody>
        ${items.map(i=>`
        <tr class="border-b border-white/5 hover:bg-white/5" id="row-${i.id}">
          <td class="px-5 py-3">
            <div class="flex items-center gap-3">
              ${i.imageUrl?`<img src="${i.imageUrl}" class="h-10 w-16 rounded-lg object-cover shrink-0"/>`:'<div class="h-10 w-16 rounded-lg bg-white/10 shrink-0"></div>'}
              <div>
                <p class="font-medium text-white">${i.title}</p>
                <p class="text-xs text-slate-500">${i.slug}</p>
              </div>
            </div>
          </td>
          <td class="px-5 py-3 max-w-xs"><p class="truncate text-slate-400 text-xs">${i.excerpt||'—'}</p></td>
          <td class="px-5 py-3">
            <button onclick="toggleStatus('${i.id}',${i.isPublished},'blogs')"
              class="rounded-full px-2.5 py-0.5 text-xs font-semibold ${i.isPublished?'bg-emerald-500/20 text-emerald-400':'bg-slate-500/20 text-slate-400'}">
              ${i.isPublished?'Published':'Draft'}
            </button>
          </td>
          <td class="px-5 py-3 text-slate-400 text-xs">${new Date(i.createdAt).toLocaleDateString('en-GB')}</td>
          <td class="px-5 py-3">
            <div class="flex gap-2">
              <button onclick='openEdit(${JSON.stringify(i).replace(/'/g,"\\'")})'
                class="rounded-lg border border-white/10 px-3 py-1.5 text-xs text-slate-300 hover:bg-white/5">Edit</button>
              <button onclick="deleteItem('${i.id}','blogs')"
                class="rounded-lg border border-red-500/30 px-3 py-1.5 text-xs text-red-400 hover:bg-red-500/10">Delete</button>
            </div>
          </td>
        </tr>`).join('')}
        ${items.length===0?'<tr><td colspan="5" class="px-5 py-10 text-center text-slate-500">No blogs yet.</td></tr>':''}
      </tbody>
    </table>
  </div>
</div>

<!-- Add Modal -->
<div id="addModal" class="hidden fixed inset-0 z-50 flex items-center justify-center bg-black/70 p-4">
  <div class="w-full max-w-lg rounded-2xl border border-white/10 bg-[#0a1428] p-6">
    <h2 class="mb-4 text-lg font-semibold text-white">Add Blog</h2>
    <div id="addMsg" class="hidden mb-3 rounded-lg px-4 py-2 text-sm"></div>
    <form id="addForm" class="grid grid-cols-2 gap-3">
      <input id="addSlug" placeholder="Slug *" required class="rounded-xl border border-white/10 bg-[#000b1a] px-3 py-2.5 text-sm text-white focus:border-sky focus:outline-none"/>
      <input id="addTitle" placeholder="Title *" required class="rounded-xl border border-white/10 bg-[#000b1a] px-3 py-2.5 text-sm text-white focus:border-sky focus:outline-none"/>
      <input id="addImageUrl" placeholder="Image URL" class="col-span-2 rounded-xl border border-white/10 bg-[#000b1a] px-3 py-2.5 text-sm text-white focus:border-sky focus:outline-none"/>
      <textarea id="addExcerpt" placeholder="Excerpt (short summary)" rows="2" class="col-span-2 rounded-xl border border-white/10 bg-[#000b1a] px-3 py-2.5 text-sm text-white focus:border-sky focus:outline-none resize-none"></textarea>
      <textarea id="addContent" placeholder="Full content" rows="4" class="col-span-2 rounded-xl border border-white/10 bg-[#000b1a] px-3 py-2.5 text-sm text-white focus:border-sky focus:outline-none resize-none"></textarea>
      <div class="col-span-2 flex justify-end gap-2 pt-1">
        <button type="button" onclick="document.getElementById('addModal').classList.add('hidden')" class="rounded-xl border border-white/10 px-4 py-2 text-sm text-slate-300">Cancel</button>
        <button type="submit" class="rounded-xl bg-gradient-to-r from-cyan-500 to-blue-600 px-4 py-2 text-sm font-semibold text-white">Publish</button>
      </div>
    </form>
  </div>
</div>

<!-- Edit Modal -->
<div id="editModal" class="hidden fixed inset-0 z-50 flex items-center justify-center bg-black/70 p-4">
  <div class="w-full max-w-lg rounded-2xl border border-white/10 bg-[#0a1428] p-6">
    <h2 class="mb-4 text-lg font-semibold text-white">Edit Blog</h2>
    <div id="editMsg" class="hidden mb-3 rounded-lg px-4 py-2 text-sm"></div>
    <form id="editForm" class="grid grid-cols-2 gap-3">
      <input id="editId" type="hidden"/>
      <input id="editTitle" placeholder="Title *" required class="col-span-2 rounded-xl border border-white/10 bg-[#000b1a] px-3 py-2.5 text-sm text-white focus:border-sky focus:outline-none"/>
      <input id="editImageUrl" placeholder="Image URL" class="col-span-2 rounded-xl border border-white/10 bg-[#000b1a] px-3 py-2.5 text-sm text-white focus:border-sky focus:outline-none"/>
      <textarea id="editExcerpt" placeholder="Excerpt" rows="2" class="col-span-2 rounded-xl border border-white/10 bg-[#000b1a] px-3 py-2.5 text-sm text-white focus:border-sky focus:outline-none resize-none"></textarea>
      <textarea id="editContent" placeholder="Full content" rows="4" class="col-span-2 rounded-xl border border-white/10 bg-[#000b1a] px-3 py-2.5 text-sm text-white focus:border-sky focus:outline-none resize-none"></textarea>
      <div class="col-span-2 flex justify-end gap-2 pt-1">
        <button type="button" onclick="document.getElementById('editModal').classList.add('hidden')" class="rounded-xl border border-white/10 px-4 py-2 text-sm text-slate-300">Cancel</button>
        <button type="submit" class="rounded-xl bg-gradient-to-r from-cyan-500 to-blue-600 px-4 py-2 text-sm font-semibold text-white">Save</button>
      </div>
    </form>
  </div>
</div>

<script>
  var token=localStorage.getItem('cnc_token');
  function showMsg(id,t,e){var el=document.getElementById(id);el.textContent=t;el.className='mb-3 rounded-lg px-4 py-2 text-sm '+(e?'bg-red-500/20 text-red-400':'bg-green-500/20 text-green-400');el.classList.remove('hidden');}
  function openEdit(i){document.getElementById('editId').value=i.id;document.getElementById('editTitle').value=i.title||'';document.getElementById('editImageUrl').value=i.imageUrl||'';document.getElementById('editExcerpt').value=i.excerpt||'';document.getElementById('editContent').value=i.content||'';document.getElementById('editModal').classList.remove('hidden');}
  async function toggleStatus(id,cur,type){await fetch('/api/admin/'+type+'/'+id,{method:'PATCH',headers:{'Content-Type':'application/json','Authorization':'Bearer '+token},body:JSON.stringify({isPublished:!cur})});location.reload();}
  async function deleteItem(id,type){if(!confirm('Delete?'))return;var r=await fetch('/api/admin/'+type+'/'+id,{method:'DELETE',headers:{'Authorization':'Bearer '+token}});if(r.ok)document.getElementById('row-'+id).remove();}
  document.getElementById('addForm').addEventListener('submit',async function(e){e.preventDefault();var r=await fetch('/api/admin/blogs',{method:'POST',headers:{'Content-Type':'application/json','Authorization':'Bearer '+token},body:JSON.stringify({slug:document.getElementById('addSlug').value,title:document.getElementById('addTitle').value,imageUrl:document.getElementById('addImageUrl').value,excerpt:document.getElementById('addExcerpt').value,content:document.getElementById('addContent').value})});var d=await r.json();if(!r.ok)return showMsg('addMsg',d.error||'Failed',true);showMsg('addMsg','Created!',false);setTimeout(()=>location.reload(),700);});
  document.getElementById('editForm').addEventListener('submit',async function(e){e.preventDefault();var id=document.getElementById('editId').value;var r=await fetch('/api/admin/blogs/'+id,{method:'PATCH',headers:{'Content-Type':'application/json','Authorization':'Bearer '+token},body:JSON.stringify({title:document.getElementById('editTitle').value,imageUrl:document.getElementById('editImageUrl').value,excerpt:document.getElementById('editExcerpt').value,content:document.getElementById('editContent').value})});var d=await r.json();if(!r.ok)return showMsg('editMsg',d.error||'Failed',true);showMsg('editMsg','Saved!',false);setTimeout(()=>location.reload(),700);});
</script>`;
%>
<%- include('layout', { pageTitle, authUser, adminNav, body }) %>

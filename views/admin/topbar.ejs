<header class="sticky top-0 z-30 flex h-16 items-center justify-between border-b border-white/10 bg-[#000b1a]/95 px-4 backdrop-blur md:px-6">
  <button id="sidebarToggle" class="rounded-lg p-2 text-slate-400 hover:bg-white/5 lg:hidden">
    <svg class="h-5 w-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16"/></svg>
  </button>
  <h1 class="text-base font-semibold text-white"><%= pageTitle %></h1>
  <div class="flex items-center gap-2">
    <span class="flex h-8 w-8 items-center justify-center rounded-full bg-gradient-to-br from-[#00a2ff] to-[#ff6600] text-xs font-bold text-white">
      <%= authUser.name.slice(0,2).toUpperCase() %>
    </span>
    <span class="hidden text-sm text-slate-300 sm:block"><%= authUser.name %></span>
  </div>
</header>

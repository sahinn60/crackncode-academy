<%
var body = `
<div class="mb-5">
  <p class="text-sm text-slate-400">${messages.length} messages total</p>
</div>
<div class="space-y-3">
  ${messages.map(m => `
  <div class="rounded-2xl border ${m.isRead ? 'border-white/10 bg-[#0a1428]' : 'border-[#00a2ff]/30 bg-[#00a2ff]/5'} p-5">
    <div class="flex flex-wrap items-start justify-between gap-3">
      <div>
        <div class="flex items-center gap-2">
          ${!m.isRead ? '<span class="h-2 w-2 rounded-full bg-[#00a2ff] shrink-0"></span>' : ''}
          <p class="font-semibold text-white">${m.name}</p>
          <span class="rounded-full bg-white/10 px-2 py-0.5 text-xs text-slate-400">${m.subject}</span>
        </div>
        <p class="mt-0.5 text-xs text-slate-500">${m.email}</p>
      </div>
      <div class="flex items-center gap-2">
        <p class="text-xs text-slate-500">${new Date(m.createdAt).toLocaleDateString('en-GB', { day:'numeric', month:'short', year:'numeric', hour:'2-digit', minute:'2-digit' })}</p>
        ${!m.isRead ? `<button onclick="markRead('${m.id}')" class="rounded-lg border border-white/10 px-3 py-1 text-xs text-slate-300 hover:bg-white/5">Mark Read</button>` : '<span class="text-xs text-slate-600">Read</span>'}
      </div>
    </div>
    <p class="mt-3 text-sm leading-relaxed text-slate-300">${m.message}</p>
  </div>`).join('')}
  ${messages.length === 0 ? '<div class="rounded-2xl border border-white/10 bg-[#0a1428] py-16 text-center text-slate-500">No messages yet.</div>' : ''}
</div>

<script>
  var token = localStorage.getItem('cnc_token');
  async function markRead(id) {
    await fetch('/api/admin/messages/' + id + '/read', {
      method: 'PATCH',
      headers: { 'Authorization': 'Bearer ' + token },
    });
    location.reload();
  }
</script>`;
%>
<%- include('layout', { pageTitle, authUser, adminNav, body }) %>

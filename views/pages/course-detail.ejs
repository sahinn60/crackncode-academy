<!DOCTYPE html>
<html lang="bn" class="scroll-smooth">
<head>
  <%- include('../partials/head') %>
</head>
<body class="min-h-screen bg-night font-display text-slate-200 antialiased">
  <%- include('../partials/navbar') %>
  <main class="mx-auto max-w-7xl px-4 py-6 md:px-6">
    <nav class="mb-4 text-sm text-slate-500">
      <a href="/" class="hover:text-sky">হোম</a>
      <span class="mx-2">›</span>
      <a href="/courses" class="hover:text-sky">কোর্স</a>
      <span class="mx-2">›</span>
      <span class="text-slate-300"><%= course.title %></span>
    </nav>
    <div class="rounded-2xl border border-sky/20 bg-gradient-to-r from-[#0a1f3d] to-card p-6 md:p-10">
      <h1 class="text-2xl font-bold text-white md:text-4xl"><%= course.title %></h1>
      <p class="mt-2 text-slate-300"><%= course.subtitle || course.description || '' %></p>
    </div>
    <div class="mt-8 grid gap-10 lg:grid-cols-[1fr_340px]">
      <div>
        <div class="flex flex-wrap gap-2 border-b border-white/10 pb-4">
          <button type="button" data-tab="info" class="tab-btn rounded-full bg-sky px-4 py-2 text-sm font-medium text-night">Information</button>
          <button type="button" data-tab="content" class="tab-btn rounded-full px-4 py-2 text-sm text-slate-300 hover:bg-white/5">Course Content</button>
          <button type="button" data-tab="instructor" class="tab-btn rounded-full px-4 py-2 text-sm text-slate-300 hover:bg-white/5">Instructor</button>
          <button type="button" data-tab="reviews" class="tab-btn rounded-full px-4 py-2 text-sm text-slate-300 hover:bg-white/5">Reviews</button>
        </div>

        <!-- Info tab -->
        <div id="panel-info" class="tab-panel mt-6 space-y-4 text-slate-300">
          <% (course.detailParagraphs || []).forEach(function(p) { %>
            <p class="text-lg font-semibold text-white"><%= p %></p>
          <% }); %>
          <p class="text-sm leading-relaxed"><%= course.description || 'এই কোর্সে আপনি আধুনিক AI টুলচেইন, রিয়েল ক্লায়েন্ট কেস স্টাডি ও বাংলায় স্টেপ-বাই-স্টেপ প্রজেক্ট শিখবেন।' %></p>
          <div class="mt-8 space-y-2">
            <% (course.modules || []).forEach(function(m) { %>
              <details class="group rounded-xl border border-white/10 bg-card open:border-sky/30">
                <summary class="flex cursor-pointer list-none items-center justify-between px-4 py-3 font-medium text-white marker:content-none [&::-webkit-details-marker]:hidden">
                  <span><%= m.title %></span>
                  <span class="text-xs text-slate-400"><%= m.lessons %> Lessons</span>
                  <svg class="h-5 w-5 shrink-0 text-slate-400 transition group-open:rotate-180" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/></svg>
                </summary>
                <div class="border-t border-white/5 px-4 py-3 text-sm text-slate-400">লেসন বিস্তারিত এখানে প্রদর্শিত হবে।</div>
              </details>
            <% }); %>
          </div>
        </div>

        <!-- Content tab -->
        <div id="panel-content" class="tab-panel mt-6 hidden text-slate-400">
          <p>কোর্স কন্টেন্ট ট্যাবে মডিউল ও লেসন লিস্ট দেখানো হয়েছে।</p>
        </div>

        <!-- Instructor tab -->
        <div id="panel-instructor" class="tab-panel mt-6 hidden">
          <div class="rounded-2xl border border-white/10 bg-card p-6">
            <p class="text-sm font-semibold uppercase tracking-wider text-slate-500">Instructor</p>
            <% if (course.instructor) { %>
            <div class="mt-4 flex items-center gap-4">
              <img src="<%= course.instructor.avatar %>" alt="" class="h-16 w-16 rounded-full object-cover ring-2 ring-sky/30" width="64" height="64" />
              <div>
                <p class="text-lg font-bold text-white"><%= course.instructor.name %></p>
                <p class="text-sm text-sky"><%= course.instructor.email %></p>
              </div>
            </div>
            <% } else { %>
            <p class="mt-4 text-slate-400">Instructor info coming soon.</p>
            <% } %>
          </div>
        </div>

        <!-- Reviews tab -->
        <div id="panel-reviews" class="tab-panel mt-6 hidden">
          <div class="rounded-2xl border border-amber-500/20 bg-amber-500/5 p-4 text-sm text-amber-100/90">
            <span class="rounded bg-amber-500/20 px-2 py-0.5 text-xs font-semibold text-amber-200">Bonus</span>
            <p class="mt-2">প্রি-অর্ডারে বোনাস মডিউল — সীমিত সময়ের জন্য।</p>
          </div>
          <div class="mt-8 flex flex-wrap items-start justify-between gap-4">
            <div>
              <p class="text-4xl font-bold text-white"><%= (course.reviewsSummary || {}).avg || 0 %></p>
              <div class="mt-1 flex text-amber-400">★★★★★</div>
              <p class="mt-1 text-sm text-slate-500">(<%= (course.reviewsSummary || {}).count || 0 %> reviews)</p>
            </div>
          </div>
          <div class="mt-6 space-y-3">
            <% [5,4,3,2,1].forEach(function(star, i) { %>
              <div class="flex items-center gap-3 text-xs">
                <span class="w-8 text-slate-400"><%= star %>★</span>
                <div class="h-2 flex-1 rounded-full bg-white/10">
                  <div class="h-full rounded-full bg-sky" style="width: <%= ((course.reviewsSummary || {}).bars || [])[i] || 0 %>%;"></div>
                </div>
              </div>
            <% }); %>
          </div>
          <div class="mt-8 space-y-4">
            <% (course.reviews || []).forEach(function(r) { %>
              <div class="rounded-xl border border-white/10 bg-card p-4">
                <div class="flex items-center gap-3">
                  <span class="flex h-10 w-10 items-center justify-center rounded-full bg-sky text-xs font-bold text-night"><%= r.initials %></span>
                  <div>
                    <p class="font-semibold text-white"><%= r.name %></p>
                    <p class="text-xs text-amber-400"><%= '★'.repeat(r.stars) %><span class="text-slate-500"> · <%= r.time %></span></p>
                  </div>
                </div>
                <p class="mt-3 text-sm text-slate-300"><%= r.text %></p>
              </div>
            <% }); %>
          </div>
        </div>
      </div>

      <!-- Sidebar -->
      <aside class="lg:sticky lg:top-24 lg:self-start">
        <div class="overflow-hidden rounded-2xl border border-white/10 bg-card shadow-xl">
          <div class="relative aspect-video bg-black/40">
            <img src="<%= course.image || course.imageUrl || '' %>" alt="" class="h-full w-full object-cover opacity-90" width="640" height="400" />
            <button type="button" class="absolute inset-0 m-auto flex h-16 w-16 items-center justify-center rounded-full bg-emerald-500 text-white shadow-lg">
              <svg class="ml-1 h-8 w-8" fill="currentColor" viewBox="0 0 24 24"><path d="M8 5v14l11-7z"/></svg>
            </button>
          </div>
          <div class="space-y-4 p-6">
            <div class="flex items-baseline gap-3">
              <span class="text-3xl font-bold text-white">৳ <%= course.price.toLocaleString("bn-BD") %></span>
              <% if (course.oldPrice) { %>
              <span class="text-sm text-slate-500 line-through">৳ <%= course.oldPrice.toLocaleString("bn-BD") %></span>
              <% } %>
            </div>
            <% if (course.discountPct || course.oldPrice) { %>
            <span class="inline-block rounded-full bg-emerald-500/20 px-3 py-1 text-xs font-semibold text-emerald-300">
              <%= course.discountPct || (course.oldPrice ? Math.round((1 - course.price/course.oldPrice)*100) : 0) %>% ছাড়
            </span>
            <% } %>
            <div class="flex items-center gap-2 text-xs text-slate-400">
              <span class="flex -space-x-2">
                <span class="h-8 w-8 rounded-full border-2 border-card bg-slate-600"></span>
                <span class="h-8 w-8 rounded-full border-2 border-card bg-slate-500"></span>
                <span class="h-8 w-8 rounded-full border-2 border-card bg-slate-400"></span>
              </span>
              <%= course.learners || 0 %> Learners Joined
            </div>
            <form action="/cart/add" method="post" class="space-y-3" data-ajax-cart>
              <input type="hidden" name="type" value="course" />
              <input type="hidden" name="slug" value="<%= course.slug %>" />
              <input type="hidden" name="redirect" value="/courses/<%= course.slug %>" />
              <button type="submit" class="flex w-full items-center justify-center gap-2 rounded-xl bg-sky py-3 font-semibold text-night hover:bg-sky/90">
                <svg class="h-5 w-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 3h2l.4 2M7 13h10l4-8H5.4"/></svg>
                Add To Cart
              </button>
            </form>
            <a href="/checkout/<%= course.slug %>" class="flex w-full items-center justify-center gap-2 rounded-xl bg-gradient-to-r from-emerald-500 to-teal-600 py-3 font-semibold text-white shadow-lg hover:opacity-95">
              <svg class="h-5 w-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z"/></svg>
              Enroll Now
            </a>
            <div>
              <p class="text-xs font-semibold uppercase text-slate-500">Course Info</p>
              <div class="mt-2 grid grid-cols-2 gap-2">
                <div class="rounded-xl border border-white/10 bg-night/40 p-3 text-center">
                  <p class="text-xs text-slate-500">Level</p>
                  <p class="text-sm font-semibold text-white"><%= course.level || '—' %></p>
                </div>
                <div class="rounded-xl border border-white/10 bg-night/40 p-3 text-center">
                  <p class="text-xs text-slate-500">Type</p>
                  <p class="text-sm font-semibold text-white"><%= course.recordType || course.courseType || '—' %></p>
                </div>
              </div>
            </div>
          </div>
        </div>
      </aside>
    </div>
  </main>
  <%- include('../partials/footer') %>
  <script>
    (function () {
      var btns = document.querySelectorAll(".tab-btn");
      var panels = { info: document.getElementById("panel-info"), content: document.getElementById("panel-content"), instructor: document.getElementById("panel-instructor"), reviews: document.getElementById("panel-reviews") };
      function show(key) {
        Object.keys(panels).forEach(function (k) { if (panels[k]) panels[k].classList.toggle("hidden", k !== key); });
        btns.forEach(function (b) {
          var on = b.getAttribute("data-tab") === key;
          b.className = on ? "tab-btn rounded-full bg-sky px-4 py-2 text-sm font-medium text-night" : "tab-btn rounded-full px-4 py-2 text-sm text-slate-300 hover:bg-white/5";
        });
      }
      btns.forEach(function (b) { b.addEventListener("click", function () { show(b.getAttribute("data-tab")); }); });
    })();
  </script>
  <%- include('../partials/scripts') %>
</body>
</html>

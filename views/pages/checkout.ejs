<!DOCTYPE html>
<html lang="bn" class="scroll-smooth">
<head>
  <%- include('../partials/head') %>
</head>
<body class="min-h-screen bg-night font-display text-slate-200 antialiased">
  <%- include('../partials/navbar') %>
  <main class="mx-auto max-w-3xl px-4 py-8 md:px-6">
    <nav class="mb-6 text-sm text-slate-500">
      <a href="/" class="hover:text-sky">হোম</a>
      <span class="mx-2">›</span>
      <% if (product.type === 'ebook') { %>
        <a href="/ebooks" class="hover:text-sky">ই-বুক</a>
      <% } else if (product.type === 'course') { %>
        <a href="/courses" class="hover:text-sky">কোর্স</a>
      <% } else if (product.type === 'workshop') { %>
        <a href="/workshops" class="hover:text-sky">ওয়ার্কশপ</a>
      <% } else { %>
        <a href="/bundles" class="hover:text-sky">বান্ডেল</a>
      <% } %>
      <span class="mx-2">›</span>
      <span class="text-slate-300">Checkout</span>
    </nav>

    <div class="rounded-2xl border border-white/10 bg-card p-6 shadow-xl md:p-8">
      <h1 class="text-center text-2xl font-bold text-white md:text-3xl">Checkout</h1>
      <p class="mt-1 text-center text-sm text-slate-400">Order Summary</p>

      <!-- Course card -->
      <div class="mt-8 flex gap-4 rounded-xl border border-white/10 bg-night/40 p-4">
        <img src="<%= product.image %>" alt="" class="h-24 w-36 shrink-0 rounded-lg object-cover" width="144" height="96" />
        <div class="min-w-0 flex-1">
          <h2 class="font-bold text-white"><%= product.title %></h2>
          <div class="mt-2 flex flex-wrap items-baseline gap-2">
            <span class="text-xl font-bold text-white">৳<%= product.price.toLocaleString("bn-BD") %></span>
            <% if (product.oldPrice != null && product.oldPrice > product.price) { %>
              <span class="text-sm text-slate-500 line-through">৳<%= product.oldPrice.toLocaleString("bn-BD") %></span>
              <span class="rounded-full bg-emerald-500/20 px-2 py-0.5 text-xs font-semibold text-emerald-300"><%= discountPct %>% ছাড়</span>
            <% } %>
          </div>
        </div>
      </div>

      <!-- Not logged in warning -->
      <% if (!authUser) { %>
      <div class="mt-4 rounded-xl border border-amber-400/40 bg-amber-950/30 p-4 text-sm text-amber-100/90">
        ⚠️ Payment করতে আগে <a href="/login" class="text-sky underline font-semibold">Login</a> করুন অথবা <a href="/login" class="text-sky underline font-semibold">Register</a> করুন।
      </div>
      <% } %>

      <!-- Error / success msg -->
      <div id="checkoutMsg" class="hidden mt-4 rounded-xl px-4 py-3 text-sm font-medium"></div>

      <!-- Payment method -->
      <div class="mt-6">
        <h3 class="flex items-center gap-2 text-lg font-semibold text-white">
          <span>💳</span> Payment Method নির্বাচন করুন
        </h3>
        <div class="mt-4 space-y-3">
          <label class="flex cursor-pointer items-center gap-3 rounded-xl border border-white/10 bg-night/40 p-4 transition has-[:checked]:border-pink-500/60 has-[:checked]:bg-pink-950/20">
            <input type="radio" name="payMethod" value="bkash" checked class="accent-pink-500" />
            <div class="flex-1">
              <p class="font-medium text-white">bKash</p>
              <p class="text-xs text-slate-400">সুবিধাজনক মোবাইল পেমেন্ট</p>
            </div>
            <span class="rounded-full bg-pink-500/20 px-2 py-0.5 text-xs font-bold text-pink-400">bKash</span>
          </label>
          <label class="flex cursor-pointer items-center gap-3 rounded-xl border border-white/10 bg-night/40 p-4 transition has-[:checked]:border-sky/50 has-[:checked]:bg-sky/5">
            <input type="radio" name="payMethod" value="sslcommerz" class="accent-sky-500" />
            <div class="flex-1">
              <p class="font-medium text-white">Nagad / Rocket / Visa / Mastercard</p>
              <p class="text-xs text-slate-400">SSLCOMMERZ</p>
            </div>
            <span class="rounded-full bg-sky/20 px-2 py-0.5 text-xs font-bold text-sky">SSL</span>
          </label>
        </div>
      </div>

      <!-- bKash form -->
      <div id="bkashForm" class="mt-5 rounded-xl border border-pink-500/30 bg-pink-950/10 p-5">
        <p class="mb-3 text-sm font-semibold text-pink-300">bKash নম্বর দিন</p>
        <input id="bkashNumber" type="tel" placeholder="01XXXXXXXXX"
          class="w-full rounded-xl border border-white/10 bg-night px-4 py-3 text-sm text-white placeholder:text-slate-500 focus:border-pink-500 focus:outline-none" />
        <p class="mt-2 text-xs text-slate-500">আপনার bKash Personal নম্বর দিন। Payment confirm হলে enrollment হবে।</p>
      </div>

      <!-- SSLCommerz info -->
      <div id="sslForm" class="hidden mt-5 rounded-xl border border-sky/30 bg-sky/5 p-5">
        <p class="text-sm text-slate-300">আপনাকে SSLCOMMERZ secure payment page এ redirect করা হবে।</p>
        <p class="mt-1 text-xs text-slate-500">Visa, Mastercard, Nagad, Rocket সব accept করা হয়।</p>
      </div>

      <!-- Order summary -->
      <div class="mt-6 rounded-xl border border-white/10 bg-night/30 p-5">
        <h3 class="flex items-center gap-2 font-semibold text-white">📄 Order Summary</h3>
        <dl class="mt-4 space-y-2 text-sm">
          <div class="flex justify-between text-slate-400">
            <dt>Price (Subtotal)</dt>
            <dd class="text-white">৳ <%= (product.oldPrice != null ? product.oldPrice : product.price).toLocaleString("bn-BD") %></dd>
          </div>
          <div class="flex justify-between text-slate-400">
            <dt>Discount (<%= discountPct %>% ছাড়)</dt>
            <dd class="text-emerald-400">− ৳ <%= discount.toLocaleString("bn-BD") %></dd>
          </div>
          <div class="flex justify-between border-t border-white/10 pt-3 text-base font-bold">
            <dt class="text-white">Total Amount</dt>
            <dd class="text-sky">৳ <%= product.price.toLocaleString("bn-BD") %></dd>
          </div>
        </dl>
      </div>

      <label class="mt-5 flex cursor-pointer items-start gap-3 text-sm text-slate-400">
        <input id="agreeCheck" type="checkbox" checked class="mt-1 accent-sky" />
        <span>আমি Terms &amp; Conditions, Privacy Policy এবং Refund Policy পড়েছি এবং সম্মত আছি।</span>
      </label>

      <button id="payBtn" type="button" onclick="handlePayment()"
        class="mt-6 flex w-full items-center justify-center gap-2 rounded-xl bg-sky py-4 text-base font-bold text-night shadow-lg transition hover:bg-sky/90 disabled:opacity-50">
        <svg class="h-5 w-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z"/></svg>
        Proceed To Payment
      </button>
    </div>
  </main>
  <%- include('../partials/footer') %>
  <%- include('../partials/scripts') %>

  <script>
    var PRODUCT_TYPE  = '<%= product.type %>';
    var PRODUCT_SLUG  = '<%= product.slug %>';
    var PRODUCT_PRICE = <%= product.price %>;
    var PRODUCT_TITLE = '<%= encodeURIComponent(product.title) %>';

    document.querySelectorAll('input[name="payMethod"]').forEach(function(r) {
      r.addEventListener('change', function() {
        document.getElementById('bkashForm').classList.toggle('hidden', this.value !== 'bkash');
        document.getElementById('sslForm').classList.toggle('hidden', this.value !== 'sslcommerz');
      });
    });

    function showMsg(text, isError) {
      var el = document.getElementById('checkoutMsg');
      el.textContent = text;
      el.className = 'mt-4 rounded-xl px-4 py-3 text-sm font-medium ' +
        (isError ? 'bg-red-500/20 text-red-400 border border-red-500/30'
                 : 'bg-green-500/20 text-green-400 border border-green-500/30');
      el.classList.remove('hidden');
      el.scrollIntoView({ behavior: 'smooth', block: 'center' });
    }

    async function handlePayment() {
      var token = localStorage.getItem('cnc_token');
      if (!token) {
        showMsg('Payment করতে আগে Login করুন।', true);
        setTimeout(function() { window.location.href = '/login'; }, 1500);
        return;
      }
      if (!document.getElementById('agreeCheck').checked) {
        showMsg('Terms & Conditions এ সম্মত হতে হবে।', true);
        return;
      }
      var method = document.querySelector('input[name="payMethod"]:checked').value;
      if (method === 'bkash') {
        var bkashNum = document.getElementById('bkashNumber').value.trim();
        if (!bkashNum || bkashNum.length < 11) {
          showMsg('সঠিক bKash নম্বর দিন।', true);
          return;
        }
      }
      var btn = document.getElementById('payBtn');
      btn.disabled = true;
      btn.textContent = 'Processing…';
      try {
        var orderRes = await fetch('/api/orders', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json', 'Authorization': 'Bearer ' + token },
          body: JSON.stringify({
            items: [{ productType: PRODUCT_TYPE.toUpperCase(), productSlug: PRODUCT_SLUG, courseId: null, price: PRODUCT_PRICE }]
          }),
        });
        var order = await orderRes.json();
        if (!orderRes.ok) {
          showMsg(order.error || 'Order তৈরি করতে সমস্যা হয়েছে।', true);
          btn.disabled = false; btn.textContent = 'Proceed To Payment'; return;
        }
        var payRes = await fetch('/api/orders/' + order.id + '/pay', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json', 'Authorization': 'Bearer ' + token },
          body: JSON.stringify({ method: method }),
        });
        var payData = await payRes.json();
        if (!payRes.ok) {
          showMsg(payData.error || 'Payment failed।', true);
          btn.disabled = false; btn.textContent = 'Proceed To Payment'; return;
        }
        window.location.href = '/payment/success?orderId=' + order.id + '&course=' + PRODUCT_TITLE;
      } catch (err) {
        showMsg('Network error। আবার চেষ্টা করুন।', true);
        btn.disabled = false; btn.textContent = 'Proceed To Payment';
      }
    }
  </script>
</body>
</html>

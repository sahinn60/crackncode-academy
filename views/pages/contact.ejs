<!DOCTYPE html>
<html lang="bn" class="scroll-smooth">
<head><%- include('../partials/head') %></head>
<body class="min-h-screen bg-[#000b1a] font-display text-slate-200 antialiased">
  <%- include('../partials/navbar') %>
  <main class="mx-auto max-w-5xl px-4 py-14 md:px-6">

    <div class="mb-12 text-center">
      <span class="rounded-full border border-sky/30 bg-sky/10 px-4 py-1.5 text-sm text-sky">Get In Touch</span>
      <h1 class="mt-4 text-4xl font-bold text-white md:text-5xl">Contact Us</h1>
      <p class="mt-3 text-slate-400">আমাদের সাথে যোগাযোগ করুন — আমরা সাহায্য করতে সদা প্রস্তুত</p>
    </div>

    <div class="grid gap-8 lg:grid-cols-5">

      <!-- Contact info -->
      <div class="lg:col-span-2 space-y-4">
        <div class="rounded-2xl border border-white/10 bg-[#0a1428] p-6">
          <h2 class="mb-5 font-semibold text-white">যোগাযোগের তথ্য</h2>
          <div class="space-y-4">
            <div class="flex items-start gap-3">
              <div class="flex h-9 w-9 shrink-0 items-center justify-center rounded-xl bg-[#00a2ff]/20 text-[#00a2ff]">
                <svg class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/></svg>
              </div>
              <div>
                <p class="text-xs text-slate-500">Email</p>
                <p class="text-sm text-white">crackncode47@gmail.com</p>
              </div>
            </div>
            <div class="flex items-start gap-3">
              <div class="flex h-9 w-9 shrink-0 items-center justify-center rounded-xl bg-[#00a2ff]/20 text-[#00a2ff]">
                <svg class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/></svg>
              </div>
              <div>
                <p class="text-xs text-slate-500">Phone</p>
                <p class="text-sm text-white">+880 1516-563876</p>
              </div>
            </div>
            <div class="flex items-start gap-3">
              <div class="flex h-9 w-9 shrink-0 items-center justify-center rounded-xl bg-[#00a2ff]/20 text-[#00a2ff]">
                <svg class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"/></svg>
              </div>
              <div>
                <p class="text-xs text-slate-500">Address</p>
                <p class="text-sm text-white">ধানমন্ডি, ঢাকা, বাংলাদেশ</p>
              </div>
            </div>
          </div>

          <div class="mt-6 border-t border-white/10 pt-5">
            <p class="mb-3 text-xs text-slate-500">Social Media</p>
            <div class="flex gap-3">
              <a href="https://www.facebook.com/profile.php?id=61583886954115" target="_blank"
                class="flex h-9 w-9 items-center justify-center rounded-xl border border-white/10 text-slate-400 transition hover:border-[#00a2ff]/50 hover:text-[#00a2ff]">
                <svg class="h-4 w-4" fill="currentColor" viewBox="0 0 24 24"><path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/></svg>
              </a>
              <a href="https://www.youtube.com/@crackncodebd" target="_blank"
                class="flex h-9 w-9 items-center justify-center rounded-xl border border-white/10 text-slate-400 transition hover:border-red-500/50 hover:text-red-400">
                <svg class="h-4 w-4" fill="currentColor" viewBox="0 0 24 24"><path d="M23.498 6.186a3.016 3.016 0 00-2.122-2.136C19.505 3.545 12 3.545 12 3.545s-7.505 0-9.377.505A3.017 3.017 0 00.502 6.186C0 8.07 0 12 0 12s0 3.93.502 5.814a3.016 3.016 0 002.122 2.136c1.871.505 9.376.505 9.376.505s7.505 0 9.377-.505a3.015 3.015 0 002.122-2.136C24 15.93 24 12 24 12s0-3.93-.502-5.814zM9.545 15.568V8.432L15.818 12l-6.273 3.568z"/></svg>
              </a>
            </div>
          </div>
        </div>

        <div class="rounded-2xl border border-white/10 bg-[#0a1428] p-5">
          <p class="text-sm font-semibold text-white">⏰ Support Hours</p>
          <p class="mt-2 text-sm text-slate-400">শনি – বৃহস্পতি: সকাল ১০টা – রাত ৮টা</p>
          <p class="text-sm text-slate-400">শুক্রবার: বিকাল ৩টা – রাত ৮টা</p>
        </div>
      </div>

      <!-- Message form -->
      <div class="lg:col-span-3">
        <div class="rounded-2xl border border-white/10 bg-[#0a1428] p-6 md:p-8">
          <h2 class="mb-6 text-lg font-semibold text-white">আমাদের Message করুন</h2>
          <div id="contactMsg" class="hidden mb-5 rounded-xl px-4 py-3 text-sm font-medium"></div>
          <form id="contactForm" class="space-y-4">
            <div class="grid gap-4 sm:grid-cols-2">
              <div>
                <label class="mb-1.5 block text-sm text-slate-300">আপনার নাম *</label>
                <input id="cName" type="text" placeholder="Full name"
                  class="w-full rounded-xl border border-white/10 bg-[#000b1a] px-4 py-3 text-sm text-white placeholder:text-slate-500 focus:border-[#00a2ff] focus:outline-none" />
              </div>
              <div>
                <label class="mb-1.5 block text-sm text-slate-300">Email *</label>
                <input id="cEmail" type="email" placeholder="you@example.com"
                  class="w-full rounded-xl border border-white/10 bg-[#000b1a] px-4 py-3 text-sm text-white placeholder:text-slate-500 focus:border-[#00a2ff] focus:outline-none" />
              </div>
            </div>
            <div>
              <label class="mb-1.5 block text-sm text-slate-300">Subject *</label>
              <select id="cSubject"
                class="w-full rounded-xl border border-white/10 bg-[#000b1a] px-4 py-3 text-sm text-white focus:border-[#00a2ff] focus:outline-none">
                <option value="">বিষয় নির্বাচন করুন</option>
                <option value="course-inquiry">Course Inquiry</option>
                <option value="payment-issue">Payment Issue</option>
                <option value="technical-support">Technical Support</option>
                <option value="refund">Refund Request</option>
                <option value="partnership">Partnership</option>
                <option value="other">Other</option>
              </select>
            </div>
            <div>
              <label class="mb-1.5 block text-sm text-slate-300">Message *</label>
              <textarea id="cMessage" rows="5" placeholder="আপনার message লিখুন..."
                class="w-full resize-none rounded-xl border border-white/10 bg-[#000b1a] px-4 py-3 text-sm text-white placeholder:text-slate-500 focus:border-[#00a2ff] focus:outline-none"></textarea>
            </div>
            <button type="submit" id="sendBtn"
              class="flex w-full items-center justify-center gap-2 rounded-xl bg-gradient-to-r from-cyan-500 to-blue-600 py-3.5 text-sm font-bold text-white shadow-lg hover:opacity-90 disabled:opacity-50">
              <svg class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 19l9 2-9-18-9 18 9-2zm0 0v-8"/></svg>
              Message পাঠান
            </button>
          </form>
        </div>
      </div>
    </div>
  </main>
  <%- include('../partials/footer') %>
  <%- include('../partials/scripts') %>

  <script>
    <% if (authUser) { %>
    document.getElementById('cName').value = '<%= authUser.name %>';
    document.getElementById('cEmail').value = '<%= authUser.email %>';
    <% } %>

    document.getElementById('contactForm').addEventListener('submit', async function(e) {
      e.preventDefault();
      var name    = document.getElementById('cName').value.trim();
      var email   = document.getElementById('cEmail').value.trim();
      var subject = document.getElementById('cSubject').value;
      var message = document.getElementById('cMessage').value.trim();
      var btn     = document.getElementById('sendBtn');
      var msgEl   = document.getElementById('contactMsg');

      if (!name || !email || !subject || !message) {
        showMsg('সব field পূরণ করুন।', true); return;
      }

      btn.disabled = true;
      btn.textContent = 'Sending…';

      try {
        var res = await fetch('/api/contact', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ name, email, subject, message }),
        });
        var data = await res.json();
        if (!res.ok) { showMsg(data.error || 'Failed to send.', true); return; }
        showMsg('✅ আপনার message পাঠানো হয়েছে! আমরা শীঘ্রই যোগাযোগ করব।', false);
        document.getElementById('contactForm').reset();
        <% if (authUser) { %>
        document.getElementById('cName').value = '<%= authUser.name %>';
        document.getElementById('cEmail').value = '<%= authUser.email %>';
        <% } %>
      } catch(err) {
        showMsg('Network error। আবার চেষ্টা করুন।', true);
      } finally {
        btn.disabled = false;
        btn.innerHTML = '<svg class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 19l9 2-9-18-9 18 9-2zm0 0v-8"/></svg> Message পাঠান';
      }
    });

    function showMsg(text, isError) {
      var el = document.getElementById('contactMsg');
      el.textContent = text;
      el.className = 'mb-5 rounded-xl px-4 py-3 text-sm font-medium ' +
        (isError ? 'bg-red-500/20 text-red-400 border border-red-500/30'
                 : 'bg-green-500/20 text-green-400 border border-green-500/30');
      el.classList.remove('hidden');
    }
  </script>
</body>
</html>

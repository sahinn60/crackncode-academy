<!DOCTYPE html>
<html lang="bn" class="scroll-smooth">
<head>
  <%- include('../partials/head') %>
</head>
<body class="min-h-screen bg-night font-display text-slate-200 antialiased">
  <%- include('../partials/navbar') %>
  <main class="flex min-h-[calc(100vh-80px)] items-center justify-center px-4 py-12">
    <div class="w-full max-w-md text-center">
      <div class="mx-auto flex h-24 w-24 items-center justify-center rounded-full bg-red-500/20 border-2 border-red-500/40">
        <svg class="h-12 w-12 text-red-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/>
        </svg>
      </div>
      <h1 class="mt-6 text-3xl font-bold text-white">Payment Failed</h1>
      <p class="mt-2 text-slate-400">Payment সম্পন্ন হয়নি। আবার চেষ্টা করুন।</p>
      <div class="mt-8 flex flex-col gap-3 sm:flex-row sm:justify-center">
        <a href="javascript:history.back()" class="rounded-xl bg-gradient-to-r from-cyan-500 to-blue-600 px-6 py-3 text-sm font-bold text-white">
          আবার চেষ্টা করুন
        </a>
        <a href="/courses" class="rounded-xl border border-white/10 px-6 py-3 text-sm font-semibold text-slate-300 hover:bg-white/5">
          Courses দেখুন
        </a>
      </div>
    </div>
  </main>
  <%- include('../partials/scripts') %>
</body>
</html>

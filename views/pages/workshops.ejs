<!DOCTYPE html>
<html lang="bn" class="scroll-smooth">
<head>
  <%- include('../partials/head') %>
</head>
<body class="min-h-screen bg-night font-display text-slate-200 antialiased">
  <%- include('../partials/navbar') %>
  <main class="mx-auto max-w-7xl px-4 py-8 md:px-6">
    <nav class="mb-6 text-sm text-slate-500">
      <a href="/" class="hover:text-sky">হোম</a>
      <span class="mx-2">›</span>
      <span class="text-slate-300">ওয়ার্কশপ</span>
    </nav>
    <div class="grid gap-8 lg:grid-cols-[260px_1fr]">
      <%- include('../partials/sidebar-filters', { filterTypeLabel: 'ওয়ার্কশপ টাইপ' }) %>
      <div>
        <div class="mb-6 flex flex-col gap-4 sm:flex-row sm:items-center sm:justify-between">
          <h1 class="text-2xl font-bold text-white md:text-3xl"><%= count %> Workshops Found</h1>
          <select class="rounded-xl border border-white/10 bg-[#0a1428] px-4 py-2.5 text-sm text-white sm:w-56">
            <option>Default Sorting</option>
          </select>
        </div>
        <div class="grid gap-6 md:grid-cols-2 xl:grid-cols-3">
          <% workshops.forEach(function (w) { %>
            <article class="flex flex-col overflow-hidden rounded-2xl border border-white/10 bg-card shadow-lg transition hover:border-sky/40">
              <a href="/workshops/<%= w.slug %>" class="relative block aspect-video overflow-hidden">
                <img src="<%= w.image %>" alt="" class="h-full w-full object-cover transition hover:scale-105 duration-300" loading="lazy" width="640" height="400" />
                <span class="absolute bottom-3 right-3 flex items-center gap-1 rounded-full bg-black/60 px-2 py-1 text-xs text-white">
                  <svg class="h-3.5 w-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
                  <%= w.duration %>
                </span>
              </a>
              <div class="flex flex-1 flex-col p-5">
                <h2 class="text-lg font-bold text-white"><%= w.title %></h2>
                <p class="mt-2 line-clamp-2 flex-1 text-sm text-slate-400"><%= w.desc %></p>
                <div class="mt-4 flex items-baseline gap-2">
                  <span class="text-xl font-bold text-fire">৳<%= w.price.toLocaleString("bn-BD") %></span>
                  <span class="text-sm text-slate-500 line-through">৳<%= w.old.toLocaleString("bn-BD") %></span>
                </div>
                <div class="mt-4 grid grid-cols-2 gap-2">
                  <form action="/cart/add" method="post" data-ajax-cart>
                    <input type="hidden" name="type" value="workshop" />
                    <input type="hidden" name="slug" value="<%= w.slug %>" />
                    <input type="hidden" name="redirect" value="/workshops" />
                    <button type="submit" class="flex w-full items-center justify-center gap-1 rounded-xl bg-sky py-2.5 text-sm font-semibold text-night hover:bg-sky/90">
                      <svg class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 3h2l.4 2M7 13h10l4-8H5.4"/></svg>
                      কার্ট
                    </button>
                  </form>
              <a href="/workshops/<%= w.slug %>" class="flex items-center justify-center gap-1 rounded-xl border border-sky/50 bg-night/40 py-2.5 text-sm text-sky hover:bg-sky/10">
                    <svg class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"/></svg>
                    ডিটেইলস
                  </a>
                </div>
              </div>
            </article>
          <% }); %>
        </div>
      </div>
    </div>
  </main>
  <%- include('../partials/footer') %>
  <button type="button" id="toTop" class="fixed bottom-6 right-6 z-50 flex h-12 w-12 items-center justify-center rounded-full bg-sky text-night opacity-0 pointer-events-none transition-opacity" aria-label="উপরে">
    <svg class="h-5 w-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 10l7-7m0 0l7 7m-7-7v18"/></svg>
  </button>
  <%- include('../partials/scripts') %>
</body>
</html>

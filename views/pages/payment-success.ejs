<!DOCTYPE html>
<html lang="bn" class="scroll-smooth">
<head>
  <%- include('../partials/head') %>
</head>
<body class="min-h-screen bg-night font-display text-slate-200 antialiased">
  <%- include('../partials/navbar') %>
  <main class="flex min-h-[calc(100vh-80px)] items-center justify-center px-4 py-12">
    <div class="w-full max-w-md text-center">
      <!-- Success icon -->
      <div class="mx-auto flex h-24 w-24 items-center justify-center rounded-full bg-emerald-500/20 border-2 border-emerald-500/40">
        <svg class="h-12 w-12 text-emerald-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/>
        </svg>
      </div>

      <h1 class="mt-6 text-3xl font-bold text-white">Payment Successful!</h1>
      <p class="mt-2 text-slate-400">আপনার payment সফলভাবে সম্পন্ন হয়েছে।</p>

      <div class="mt-6 rounded-2xl border border-white/10 bg-card p-5 text-left space-y-3">
        <div class="flex justify-between text-sm">
          <span class="text-slate-400">Order ID</span>
          <span class="font-mono text-white text-xs"><%= orderId.slice(0,20) %>…</span>
        </div>
        <div class="flex justify-between text-sm">
          <span class="text-slate-400">Course</span>
          <span class="text-white text-right max-w-[200px]"><%= courseName %></span>
        </div>
        <div class="flex justify-between text-sm">
          <span class="text-slate-400">Status</span>
          <span class="rounded-full bg-emerald-500/20 px-2.5 py-0.5 text-xs font-semibold text-emerald-400">PAID</span>
        </div>
      </div>

      <p class="mt-4 text-sm text-slate-400">আপনি এখন এই course এ enrolled আছেন। My Courses থেকে access করুন।</p>

      <div class="mt-8 flex flex-col gap-3 sm:flex-row sm:justify-center">
        <a href="/profile" class="rounded-xl bg-gradient-to-r from-cyan-500 to-blue-600 px-6 py-3 text-sm font-bold text-white shadow-lg hover:opacity-90">
          My Courses দেখুন
        </a>
        <a href="/courses" class="rounded-xl border border-white/10 px-6 py-3 text-sm font-semibold text-slate-300 hover:bg-white/5">
          আরও Course দেখুন
        </a>
      </div>
    </div>
  </main>
  <%- include('../partials/scripts') %>
</body>
</html>

<!DOCTYPE html>
<html lang="en" class="scroll-smooth">
<head>
  <%- include('../partials/head') %>
</head>
<body class="min-h-screen bg-night font-display text-slate-200 antialiased">
  <%- include('../partials/navbar') %>

  <main class="mx-auto max-w-4xl px-4 py-10 md:px-6">
    <div class="rounded-3xl border border-white/10 bg-card p-6 md:p-10">
      <h1 class="text-2xl font-bold text-white md:text-3xl"><%= heading || pageTitle || 'Info' %></h1>
      <p class="mt-3 text-sm leading-7 text-slate-300">
        This page is ready. Replace this placeholder content with your real policy/company information.
      </p>
      <div class="mt-6 flex flex-wrap gap-3">
        <a href="/" class="rounded-xl bg-sky px-4 py-2 text-sm font-semibold text-night hover:bg-sky/90">Go Home</a>
        <a href="/contact" class="rounded-xl border border-white/15 bg-night/40 px-4 py-2 text-sm font-semibold text-white hover:bg-white/5">Contact</a>
      </div>
    </div>
  </main>

  <%- include('../partials/footer') %>
  <%- include('../partials/scripts') %>
</body>
</html>


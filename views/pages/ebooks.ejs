<!DOCTYPE html>
<html lang="bn" class="scroll-smooth">
<head>
  <%- include('../partials/head') %>
</head>
<body class="min-h-screen bg-night font-display text-slate-200 antialiased">
  <%- include('../partials/navbar') %>
  <main class="mx-auto max-w-7xl px-4 py-8 md:px-6">
    <nav class="mb-6 text-sm text-slate-500">
      <a href="/" class="hover:text-sky">হোম</a>
      <span class="mx-2">›</span>
      <span class="text-slate-300">ই-বুক</span>
    </nav>
    <div class="grid gap-8 lg:grid-cols-[240px_1fr]">
      <aside class="h-fit space-y-4 rounded-2xl border border-white/10 bg-card p-5">
        <div>
          <p class="font-semibold text-white">ক্যাটাগরি</p>
          <div class="mt-3 space-y-2 text-sm text-slate-300">
            <label class="flex cursor-pointer items-center gap-2"><input type="checkbox" checked class="rounded border-white/20 bg-night text-sky" /> সব</label>
            <label class="flex cursor-pointer items-center gap-2"><input type="checkbox" class="rounded border-white/20 bg-night text-sky" /> AI</label>
            <label class="flex cursor-pointer items-center gap-2"><input type="checkbox" class="rounded border-white/20 bg-night text-sky" /> ক্যারিয়ার</label>
          </div>
        </div>
        <div>
          <p class="font-semibold text-white">দাম</p>
          <div class="mt-2 flex gap-2">
            <button type="button" class="flex-1 rounded-lg border border-white/15 py-2 text-xs text-slate-300">ফ্রি</button>
            <button type="button" class="flex-1 rounded-lg border border-sky/50 bg-sky/10 py-2 text-xs text-sky">পেইড</button>
          </div>
          <div class="mt-3 flex gap-2">
            <input type="number" value="0" class="w-full rounded-lg border border-white/10 bg-night px-2 py-2 text-sm text-white" />
            <input type="number" value="399" class="w-full rounded-lg border border-white/10 bg-night px-2 py-2 text-sm text-white" />
          </div>
          <div class="mt-3 h-2 rounded-full bg-white/10">
            <div class="h-full w-2/3 rounded-full bg-sky"></div>
          </div>
        </div>
      </aside>
      <div>
        <div class="mb-6 flex flex-col gap-4 sm:flex-row sm:items-center sm:justify-between">
          <h1 class="text-2xl font-bold text-white md:text-3xl"><%= count %> E-Books Found</h1>
          <select class="rounded-xl border border-white/10 bg-[#0a1428] px-4 py-2.5 text-sm text-white sm:w-56">
            <option>Default Sorting</option>
          </select>
        </div>
        <div class="grid gap-6 sm:grid-cols-2 lg:grid-cols-4">
          <% ebooks.forEach(function (b) { %>
            <article id="ebook-<%= b.slug %>" class="overflow-hidden rounded-2xl border border-white/10 bg-card p-3 transition hover:border-sky/35 scroll-mt-24">
              <a href="/ebooks/<%= b.slug %>" class="block">
                <div class="overflow-hidden rounded-xl ring-1 ring-white/10">
                  <img src="<%= b.cover %>" alt="" class="aspect-[3/4] w-full object-cover" loading="lazy" width="400" height="520" />
                </div>
              </a>
              <a href="/ebooks/<%= b.slug %>" class="block">
                <h2 class="mt-3 line-clamp-2 text-sm font-semibold text-white hover:text-sky"><%= b.title %></h2>
              </a>
              <p class="text-xs text-sky/90">By <%= b.author %></p>
              <div class="mt-3 flex items-center justify-between gap-2">
                <div>
                  <span class="text-lg font-bold text-fire">৳<%= b.price %></span>
                  <span class="ml-1 text-xs text-slate-500 line-through">৳<%= b.old %></span>
                </div>
                <div class="flex items-center gap-2">
                  <form action="/cart/add" method="post" class="inline" data-ajax-cart>
                    <input type="hidden" name="type" value="ebook" />
                    <input type="hidden" name="slug" value="<%= b.slug %>" />
                    <input type="hidden" name="redirect" value="/ebooks#ebook-<%= b.slug %>" />
                    <button type="submit" class="flex items-center gap-1 rounded-lg bg-sky px-2 py-1.5 text-xs font-semibold text-night hover:bg-sky/90">
                      <svg class="h-3.5 w-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 3h2l.4 2M7 13h10l4-8H5.4M7 13l-1.5 6H19"/></svg>
                      Cart
                    </button>
                  </form>
                  <a href="/ebooks/<%= b.slug %>" class="flex items-center gap-1 rounded-lg border border-sky/40 bg-night/40 px-2 py-1.5 text-xs text-sky hover:bg-sky/10">
                    <svg class="h-3.5 w-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0 3 3 0 016 0z"/></svg>
                    Details
                  </a>
                </div>
              </div>
            </article>
          <% }); %>
        </div>
      </div>
    </div>
  </main>
  <%- include('../partials/footer') %>
  <button type="button" id="toTop" class="fixed bottom-6 right-6 z-50 flex h-12 w-12 items-center justify-center rounded-full bg-sky text-night opacity-0 pointer-events-none transition-opacity" aria-label="উপরে">
    <svg class="h-5 w-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 10l7-7m0 0l7 7m-7-7v18"/></svg>
  </button>
  <%- include('../partials/scripts') %>
</body>
</html>

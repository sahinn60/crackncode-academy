<!DOCTYPE html>
<html lang="bn" class="scroll-smooth">
<head>
  <%- include('../partials/head') %>
</head>
<body class="min-h-screen bg-[#000b1a] font-display text-slate-200 antialiased">
  <%- include('../partials/navbar') %>
  <main class="flex min-h-[calc(100vh-80px)] flex-col items-center justify-center px-4 py-12">
    <div class="mb-8 text-center">
      <div class="mx-auto mb-2 flex h-14 w-14 items-center justify-center rounded-full bg-gradient-to-br from-[#00a2ff] to-[#ff6600] text-lg font-bold text-white">CN</div>
      <p class="text-lg font-semibold text-white">CrackNcode <span class="text-fire">Academy</span></p>
    </div>

    <div class="w-full max-w-md rounded-2xl border border-white/10 bg-[#0a1428]/90 p-8 shadow-2xl">
      <!-- Tab switcher -->
      <div class="mb-2 grid grid-cols-2 gap-2 rounded-xl border border-white/10 p-1">
        <button id="tabLogin" class="rounded-lg bg-gradient-to-r from-cyan-500 to-blue-600 py-2.5 text-sm font-semibold text-white">Login</button>
        <button id="tabRegister" class="rounded-lg py-2.5 text-sm text-slate-300 hover:bg-white/5">Register</button>
      </div>

      <!-- Error / success banner -->
      <div id="authMsg" class="hidden mt-4 rounded-lg px-4 py-3 text-sm font-medium"></div>

      <!-- LOGIN FORM -->
      <form id="formLogin" class="mt-6 space-y-4">
        <div>
          <label class="text-sm text-white">Email *</label>
          <input id="loginEmail" type="email" name="email" placeholder="you@example.com"
            class="mt-1 w-full rounded-xl border border-white/10 bg-night px-3 py-3 text-sm text-white placeholder:text-slate-500 focus:border-sky focus:outline-none" />
        </div>
        <div>
          <label class="text-sm text-white">Password *</label>
          <div class="relative mt-1">
            <input id="loginPassword" type="password" name="password" placeholder="••••••••"
              class="w-full rounded-xl border border-white/10 bg-night px-3 py-3 text-sm text-white placeholder:text-slate-500 focus:border-sky focus:outline-none" />
            <button type="button" onclick="togglePwd('loginPassword')" class="absolute right-3 top-1/2 -translate-y-1/2 text-slate-400">👁</button>
          </div>
          <div class="mt-2 text-right"><a href="#" class="text-sm text-sky hover:underline">Forgot Password?</a></div>
        </div>
        <button type="submit" id="loginBtn"
          class="w-full rounded-xl bg-gradient-to-r from-cyan-500 to-blue-600 py-3 text-sm font-bold text-white shadow-lg disabled:opacity-60">
          Login
        </button>
      </form>

      <!-- REGISTER FORM -->
      <form id="formRegister" class="mt-6 hidden space-y-4">
        <div>
          <label class="text-sm text-white">Full Name *</label>
          <input id="regName" type="text" name="name" placeholder="Your name"
            class="mt-1 w-full rounded-xl border border-white/10 bg-night px-3 py-3 text-sm text-white placeholder:text-slate-500 focus:border-sky focus:outline-none" />
        </div>
        <div>
          <label class="text-sm text-white">Email *</label>
          <input id="regEmail" type="email" name="email" placeholder="you@example.com"
            class="mt-1 w-full rounded-xl border border-white/10 bg-night px-3 py-3 text-sm text-white placeholder:text-slate-500 focus:border-sky focus:outline-none" />
        </div>
        <div>
          <label class="text-sm text-white">Password *</label>
          <div class="relative mt-1">
            <input id="regPassword" type="password" name="password" placeholder="Min 6 characters"
              class="w-full rounded-xl border border-white/10 bg-night px-3 py-3 text-sm text-white placeholder:text-slate-500 focus:border-sky focus:outline-none" />
            <button type="button" onclick="togglePwd('regPassword')" class="absolute right-3 top-1/2 -translate-y-1/2 text-slate-400">👁</button>
          </div>
        </div>
        <button type="submit" id="registerBtn"
          class="w-full rounded-xl bg-gradient-to-r from-cyan-500 to-blue-600 py-3 text-sm font-bold text-white shadow-lg disabled:opacity-60">
          Create Account
        </button>
      </form>

      <p class="mt-6 text-center text-sm text-slate-400" id="switchHint">
        Don't have an account? <button id="switchToRegister" class="text-sky hover:underline">Sign Up</button>
      </p>
    </div>

    <a href="/" class="mt-8 inline-flex items-center gap-2 rounded-full border border-white/20 px-5 py-2 text-sm text-slate-300 hover:bg-white/5">← Go Back</a>
  </main>

  <script>
    // ── helpers ──────────────────────────────────────────
    function togglePwd(id) {
      var el = document.getElementById(id);
      el.type = el.type === "password" ? "text" : "password";
    }

    function showMsg(text, isError) {
      var el = document.getElementById("authMsg");
      el.textContent = text;
      el.className = "mt-4 rounded-lg px-4 py-3 text-sm font-medium " +
        (isError ? "bg-red-500/20 text-red-400 border border-red-500/30" : "bg-green-500/20 text-green-400 border border-green-500/30");
      el.classList.remove("hidden");
    }

    function setLoading(btnId, loading) {
      var btn = document.getElementById(btnId);
      btn.disabled = loading;
      btn.textContent = loading ? "Please wait…" : (btnId === "loginBtn" ? "Login" : "Create Account");
    }

    // ── tab switching ─────────────────────────────────────
    var tabLogin    = document.getElementById("tabLogin");
    var tabRegister = document.getElementById("tabRegister");
    var formLogin   = document.getElementById("formLogin");
    var formReg     = document.getElementById("formRegister");
    var switchBtn   = document.getElementById("switchToRegister");
    var switchHint  = document.getElementById("switchHint");

    function showLogin() {
      formLogin.classList.remove("hidden");
      formReg.classList.add("hidden");
      tabLogin.className = "rounded-lg bg-gradient-to-r from-cyan-500 to-blue-600 py-2.5 text-sm font-semibold text-white";
      tabRegister.className = "rounded-lg py-2.5 text-sm text-slate-300 hover:bg-white/5";
      switchHint.innerHTML = 'Don\'t have an account? <button id="switchToRegister" class="text-sky hover:underline" onclick="showRegister()">Sign Up</button>';
      document.getElementById("authMsg").classList.add("hidden");
    }

    function showRegister() {
      formReg.classList.remove("hidden");
      formLogin.classList.add("hidden");
      tabRegister.className = "rounded-lg bg-gradient-to-r from-cyan-500 to-blue-600 py-2.5 text-sm font-semibold text-white";
      tabLogin.className = "rounded-lg py-2.5 text-sm text-slate-300 hover:bg-white/5";
      switchHint.innerHTML = 'Already have an account? <button class="text-sky hover:underline" onclick="showLogin()">Login</button>';
      document.getElementById("authMsg").classList.add("hidden");
    }

    tabLogin.addEventListener("click", showLogin);
    tabRegister.addEventListener("click", showRegister);
    if (switchBtn) switchBtn.addEventListener("click", showRegister);

    // ── login submit ──────────────────────────────────────
    formLogin.addEventListener("submit", async function (e) {
      e.preventDefault();
      var email    = document.getElementById("loginEmail").value.trim();
      var password = document.getElementById("loginPassword").value;
      if (!email || !password) return showMsg("Email and password are required.", true);

      setLoading("loginBtn", true);
      try {
        var res = await fetch("/api/auth/login", {
          method: "POST",
          headers: { "Content-Type": "application/json" },
          credentials: "include",
          body: JSON.stringify({ email, password }),
        });
        var data = await res.json();
        if (!res.ok) return showMsg(data.error || "Login failed.", true);

        localStorage.setItem("cnc_token", data.token);
        localStorage.setItem("cnc_user", JSON.stringify(data.user));
        showMsg("Login successful! Redirecting…", false);
        setTimeout(function () {
          window.location.href = data.user.role === "ADMIN" ? "/admin" : "/";
        }, 800);
      } catch (err) {
        showMsg("Network error. Please try again.", true);
      } finally {
        setLoading("loginBtn", false);
      }
    });

    // ── register submit ───────────────────────────────────
    formReg.addEventListener("submit", async function (e) {
      e.preventDefault();
      var name     = document.getElementById("regName").value.trim();
      var email    = document.getElementById("regEmail").value.trim();
      var password = document.getElementById("regPassword").value;
      if (!name || !email || !password) return showMsg("All fields are required.", true);
      if (password.length < 6) return showMsg("Password must be at least 6 characters.", true);

      setLoading("registerBtn", true);
      try {
        var res = await fetch("/api/auth/register", {
          method: "POST",
          headers: { "Content-Type": "application/json" },
          credentials: "include",
          body: JSON.stringify({ name, email, password }),
        });
        var data = await res.json();
        if (!res.ok) return showMsg(data.error || "Registration failed.", true);

        localStorage.setItem("cnc_token", data.token);
        localStorage.setItem("cnc_user", JSON.stringify(data.user));
        showMsg("Account created! Redirecting…", false);
        setTimeout(function () { window.location.href = "/"; }, 800);
      } catch (err) {
        showMsg("Network error. Please try again.", true);
      } finally {
        setLoading("registerBtn", false);
      }
    });
  </script>
  <%- include('../partials/scripts') %>
</body>
</html>

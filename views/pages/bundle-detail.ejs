<!DOCTYPE html>
<html lang="bn" class="scroll-smooth">
<head><%- include('../partials/head') %></head>
<body class="min-h-screen bg-night font-display text-slate-200 antialiased">
  <%- include('../partials/navbar') %>
  <main class="mx-auto max-w-5xl px-4 py-8 md:px-6">
    <nav class="mb-6 text-sm text-slate-500">
      <a href="/" class="hover:text-sky">হোম</a><span class="mx-2">›</span>
      <a href="/bundles" class="hover:text-sky">বান্ডেল</a><span class="mx-2">›</span>
      <span class="text-slate-300"><%= bundle.title %></span>
    </nav>

    <div class="grid gap-8 lg:grid-cols-[1fr_320px]">
      <!-- Left -->
      <div>
        <div class="overflow-hidden rounded-2xl border border-amber-400/20 ring-2 ring-amber-400/10">
          <img src="<%= bundle.image || bundle.imageUrl || '' %>" alt="" class="w-full aspect-video object-cover" />
        </div>
        <h1 class="mt-6 text-2xl font-bold text-white md:text-3xl"><%= bundle.title %></h1>
        <p class="mt-3 text-slate-400 leading-relaxed">এই বান্ডেলে একাধিক কোর্স ও রিসোর্স একসাথে পাবেন বিশেষ ছাড়ে। একবার কিনলে সব কন্টেন্টে lifetime access পাবেন।</p>

        <div class="mt-6 grid grid-cols-2 gap-3 sm:grid-cols-3">
          <div class="rounded-xl border border-white/10 bg-card p-4 text-center">
            <p class="text-2xl font-bold text-sky">∞</p>
            <p class="mt-1 text-xs text-slate-400">Lifetime Access</p>
          </div>
          <div class="rounded-xl border border-white/10 bg-card p-4 text-center">
            <p class="text-2xl font-bold text-emerald-400">✓</p>
            <p class="mt-1 text-xs text-slate-400">Certificate</p>
          </div>
          <div class="rounded-xl border border-white/10 bg-card p-4 text-center">
            <p class="text-2xl font-bold text-amber-400">★</p>
            <p class="mt-1 text-xs text-slate-400">Premium Content</p>
          </div>
        </div>

        <div class="mt-8 rounded-2xl border border-white/10 bg-card p-6">
          <h2 class="font-semibold text-white mb-3">এই বান্ডেলে কী আছে</h2>
          <ul class="space-y-2 text-sm text-slate-300">
            <li class="flex items-center gap-2"><span class="text-emerald-400">✓</span> সব কোর্সে সম্পূর্ণ access</li>
            <li class="flex items-center gap-2"><span class="text-emerald-400">✓</span> ডাউনলোডযোগ্য রিসোর্স ও টেমপ্লেট</li>
            <li class="flex items-center gap-2"><span class="text-emerald-400">✓</span> Community support</li>
            <li class="flex items-center gap-2"><span class="text-emerald-400">✓</span> Future updates বিনামূল্যে</li>
          </ul>
        </div>
      </div>

      <!-- Sidebar -->
      <aside class="lg:sticky lg:top-24 lg:self-start">
        <div class="rounded-2xl border border-white/10 bg-card p-6 space-y-4">
          <div class="flex items-baseline gap-3">
            <span class="text-3xl font-bold text-[#ff6600]">৳ <%= bundle.price.toLocaleString("bn-BD") %></span>
            <% if (bundle.old || bundle.oldPrice) { %>
            <span class="text-sm text-slate-500 line-through">৳ <%= (bundle.old || bundle.oldPrice).toLocaleString("bn-BD") %></span>
            <% } %>
          </div>
          <% if (bundle.old || bundle.oldPrice) { %>
          <span class="inline-block rounded-full bg-emerald-500/20 px-3 py-1 text-xs font-semibold text-emerald-300">
            <%= Math.round((1 - bundle.price / (bundle.old || bundle.oldPrice)) * 100) %>% ছাড়
          </span>
          <% } %>

          <!-- Cart -->
          <form action="/cart/add" method="post">
            <input type="hidden" name="type" value="bundle" />
            <input type="hidden" name="slug" value="<%= bundle.id || bundle.slug %>" />
            <input type="hidden" name="redirect" value="/bundles/<%= bundle.id || bundle.slug %>" />
            <button type="submit" class="flex w-full items-center justify-center gap-2 rounded-xl border border-sky/50 bg-sky/10 py-3 text-sm font-semibold text-sky hover:bg-sky/20">
              <svg class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 3h2l.4 2M7 13h10l4-8H5.4"/></svg>
              কার্টে যোগ করুন
            </button>
          </form>

          <!-- Buy Now -->
          <a href="/checkout?type=bundle&slug=<%= encodeURIComponent(bundle.id || bundle.slug) %>"
            class="flex w-full items-center justify-center gap-2 rounded-xl bg-gradient-to-r from-[#ff6600] to-amber-500 py-3 text-sm font-bold text-white shadow-lg hover:opacity-90">
            <svg class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z"/></svg>
            এখনই কিনুন
          </a>

          <p class="text-center text-xs text-slate-500">30-day money back guarantee</p>
        </div>
      </aside>
    </div>
  </main>
  <%- include('../partials/footer') %>
  <%- include('../partials/scripts') %>
</body>
</html>

<!DOCTYPE html>
<html lang="bn" class="scroll-smooth">
<head><%- include('../partials/head') %></head>
<body class="min-h-screen bg-night font-display text-slate-200 antialiased">
  <%- include('../partials/navbar') %>
  <main class="mx-auto max-w-5xl px-4 py-8 md:px-6">
    <nav class="mb-6 text-sm text-slate-500">
      <a href="/" class="hover:text-sky">হোম</a><span class="mx-2">›</span>
      <a href="/workshops" class="hover:text-sky">ওয়ার্কশপ</a><span class="mx-2">›</span>
      <span class="text-slate-300"><%= workshop.title %></span>
    </nav>
    <div class="grid gap-8 lg:grid-cols-[1fr_320px]">
      <div>
        <div class="overflow-hidden rounded-2xl border border-white/10">
          <img src="<%= workshop.image || workshop.imageUrl || '' %>" alt="" class="w-full aspect-video object-cover" />
        </div>
        <div class="mt-6">
          <% if (workshop.wType) { %>
            <span class="rounded-full bg-sky/20 px-3 py-1 text-xs font-semibold text-sky"><%= workshop.wType %></span>
          <% } %>
          <h1 class="mt-3 text-2xl font-bold text-white md:text-3xl"><%= workshop.title %></h1>
          <p class="mt-3 text-slate-300 leading-relaxed"><%= workshop.description || workshop.desc || '' %></p>
          <div class="mt-6 flex flex-wrap gap-4 text-sm text-slate-400">
            <% if (workshop.category) { %><span class="flex items-center gap-1">📂 <%= workshop.category %></span><% } %>
            <% if (workshop.duration) { %><span class="flex items-center gap-1">⏱ <%= workshop.duration %></span><% } %>
          </div>
        </div>
      </div>
      <aside class="lg:sticky lg:top-24 lg:self-start">
        <div class="rounded-2xl border border-white/10 bg-card p-6 space-y-4">
          <div class="flex items-baseline gap-3">
            <span class="text-3xl font-bold text-white">৳ <%= workshop.price.toLocaleString("bn-BD") %></span>
            <% if (workshop.old || workshop.oldPrice) { %>
            <span class="text-sm text-slate-500 line-through">৳ <%= (workshop.old || workshop.oldPrice).toLocaleString("bn-BD") %></span>
            <% } %>
          </div>
          <form action="/cart/add" method="post">
            <input type="hidden" name="type" value="workshop" />
            <input type="hidden" name="slug" value="<%= workshop.slug %>" />
            <input type="hidden" name="redirect" value="/workshops/<%= workshop.slug %>" />
            <button type="submit" class="w-full rounded-xl bg-sky py-3 font-semibold text-night hover:bg-sky/90">কার্টে যোগ করুন</button>
          </form>
          <a href="/checkout?type=workshop&slug=<%= workshop.slug %>" class="flex w-full items-center justify-center rounded-xl bg-gradient-to-r from-emerald-500 to-teal-600 py-3 font-semibold text-white">এখনই Enroll করুন</a>
        </div>
      </aside>
    </div>
  </main>
  <%- include('../partials/footer') %>
  <%- include('../partials/scripts') %>
</body>
</html>

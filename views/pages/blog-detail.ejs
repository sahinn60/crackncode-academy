<!DOCTYPE html>
<html lang="bn" class="scroll-smooth">
<head><%- include('../partials/head') %></head>
<body class="min-h-screen bg-night font-display text-slate-200 antialiased">
  <%- include('../partials/navbar') %>
  <main class="mx-auto max-w-3xl px-4 py-10 md:px-6">
    <nav class="mb-6 text-sm text-slate-500">
      <a href="/" class="hover:text-sky">হোম</a><span class="mx-2">›</span>
      <a href="/blog" class="hover:text-sky">ব্লগ</a><span class="mx-2">›</span>
      <span class="text-slate-300"><%= blog.title %></span>
    </nav>
    <% if (blog.imageUrl || blog.image) { %>
    <div class="overflow-hidden rounded-2xl border border-white/10 mb-8">
      <img src="<%= blog.imageUrl || blog.image %>" alt="" class="w-full aspect-video object-cover" />
    </div>
    <% } %>
    <time class="text-xs text-slate-500"><%= blog.date || new Date(blog.createdAt).toLocaleDateString('en-GB', { day:'numeric', month:'long', year:'numeric' }) %></time>
    <h1 class="mt-2 text-2xl font-bold text-white md:text-3xl"><%= blog.title %></h1>
    <% if (blog.excerpt) { %>
    <p class="mt-4 text-lg text-slate-300 leading-relaxed border-l-4 border-sky/50 pl-4"><%= blog.excerpt %></p>
    <% } %>
    <div class="mt-6 prose prose-invert max-w-none text-slate-300 leading-relaxed">
      <% if (blog.content) { %>
        <p><%= blog.content %></p>
      <% } else { %>
        <p>বিস্তারিত কন্টেন্ট শীঘ্রই আসছে।</p>
      <% } %>
    </div>
    <div class="mt-10 border-t border-white/10 pt-6">
      <a href="/blog" class="inline-flex items-center gap-2 text-sm text-sky hover:underline">
        <svg class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 19l-7-7m0 0l7-7m-7 7h18"/></svg>
        সব ব্লগ দেখুন
      </a>
    </div>
  </main>
  <%- include('../partials/footer') %>
  <%- include('../partials/scripts') %>
</body>
</html>

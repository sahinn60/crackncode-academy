<!DOCTYPE html>
<html lang="bn" class="scroll-smooth">
<head><%- include('../partials/head') %></head>
<body class="min-h-screen bg-[#000b1a] font-display text-slate-200 antialiased">
  <%- include('../partials/navbar') %>
  <main class="mx-auto max-w-5xl px-4 py-8 md:px-6">
    <nav class="mb-6 text-sm text-slate-500">
      <a href="/" class="hover:text-sky">হোম</a><span class="mx-2">›</span>
      <a href="/ebooks" class="hover:text-sky">ই-বুক</a><span class="mx-2">›</span>
      <a href="/ebooks/<%= ebook.slug %>" class="hover:text-sky"><%= ebook.title %></a><span class="mx-2">›</span>
      <span class="text-slate-300">Read</span>
    </nav>

    <div class="mb-6 flex items-center justify-between">
      <div>
        <h1 class="text-xl font-bold text-white"><%= ebook.title %></h1>
        <% if (ebook.author) { %><p class="text-sm text-slate-400">By <%= ebook.author %></p><% } %>
      </div>
      <a href="/ebooks/<%= ebook.slug %>" class="rounded-xl border border-white/10 px-4 py-2 text-sm text-slate-300 hover:bg-white/5">← Back</a>
    </div>

    <% if (ebook.fileUrl) { %>
      <% var ext = ebook.fileUrl.split('.').pop().toLowerCase(); %>
      <% if (ext === 'pdf') { %>
        <!-- PDF Viewer -->
        <div class="rounded-2xl border border-white/10 overflow-hidden bg-[#0a1428]">
          <div class="flex items-center justify-between border-b border-white/10 px-5 py-3">
            <span class="text-sm font-semibold text-white">📄 PDF Viewer</span>
            <a href="<%= ebook.fileUrl %>" target="_blank" download
              class="flex items-center gap-2 rounded-xl bg-[#00a2ff]/20 px-3 py-1.5 text-xs font-semibold text-[#00a2ff] hover:bg-[#00a2ff]/30">
              <svg class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-4l-4 4m0 0l-4-4m4 4V4"/></svg>
              Download
            </a>
          </div>
          <iframe src="<%= ebook.fileUrl %>#toolbar=1&navpanes=1&scrollbar=1"
            class="w-full" style="height: 80vh; min-height: 600px;" frameborder="0">
            <p class="p-6 text-slate-400">Browser does not support PDF viewer.
              <a href="<%= ebook.fileUrl %>" class="text-sky underline">Download PDF</a>
            </p>
          </iframe>
        </div>
      <% } else { %>
        <!-- DOC file — download only -->
        <div class="rounded-2xl border border-white/10 bg-[#0a1428] p-10 text-center">
          <div class="mx-auto mb-4 flex h-20 w-20 items-center justify-center rounded-full bg-emerald-500/20">
            <svg class="h-10 w-10 text-emerald-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"/></svg>
          </div>
          <h2 class="text-xl font-bold text-white"><%= ebook.title %></h2>
          <p class="mt-2 text-slate-400">এই ফাইলটি DOC/DOCX ফরম্যাটে। ডাউনলোড করে পড়ুন।</p>
          <a href="<%= ebook.fileUrl %>" target="_blank" download
            class="mt-6 inline-flex items-center gap-2 rounded-xl bg-gradient-to-r from-emerald-500 to-teal-600 px-6 py-3 text-sm font-bold text-white shadow-lg hover:opacity-90">
            <svg class="h-5 w-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-4l-4 4m0 0l-4-4m4 4V4"/></svg>
            ডাউনলোড করুন
          </a>
        </div>
      <% } %>
    <% } else { %>
      <div class="rounded-2xl border border-white/10 bg-[#0a1428] p-10 text-center">
        <p class="text-slate-400">এই ই-বুকের ফাইল এখনো আপলোড হয়নি। শীঘ্রই আসছে।</p>
      </div>
    <% } %>
  </main>
  <%- include('../partials/footer') %>
  <%- include('../partials/scripts') %>
</body>
</html>

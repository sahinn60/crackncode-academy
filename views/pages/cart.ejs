<!DOCTYPE html>
<html lang="bn" class="scroll-smooth">
<head>
  <%- include('../partials/head') %>
</head>
<body class="min-h-screen bg-[#000b1a] font-display text-slate-200 antialiased">
  <%- include('../partials/navbar') %>
  <main class="mx-auto max-w-7xl px-4 py-8 md:px-6">
    <nav class="mb-6 text-sm text-slate-500">
      <a href="/" class="hover:text-sky">হোম</a>
      <span class="mx-2">›</span>
      <span class="text-slate-300">Cart</span>
    </nav>
    <h1 class="text-2xl font-bold text-white md:text-3xl">
      Your Cart (<%= lineCount %> item<%= lineCount === 1 ? '' : 's' %>)
    </h1>

    <% if (!cart.length) { %>
      <div class="mt-10 flex flex-col items-center justify-center rounded-2xl border border-white/10 bg-[#0a1428] p-16 text-center">
        <svg class="h-16 w-16 text-slate-600 mb-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M3 3h2l.4 2M7 13h10l4-8H5.4M7 13L5.4 5M7 13l-2.293 2.293c-.63.63-.184 1.707.707 1.707H17m0 0a2 2 0 100 4 2 2 0 000-4zm-8 2a2 2 0 11-4 0 2 2 0 014 0z"/></svg>
        <p class="text-slate-400 text-lg">কার্ট খালি।</p>
        <a href="/courses" class="mt-4 rounded-full bg-gradient-to-r from-cyan-500 to-blue-600 px-6 py-2.5 text-sm font-semibold text-white">কোর্স ব্রাউজ করুন</a>
      </div>
    <% } else { %>
      <div class="mt-8 grid gap-8 lg:grid-cols-[1fr_380px]">

        <!-- Cart Items -->
        <div class="space-y-4">
          <% cart.forEach(function(item, index) { %>
            <%
              var qty = item.qty || 1;
              var oldP = item.oldPrice != null ? item.oldPrice : item.price;
              var lineTotal = item.price * qty;
              var discPct = oldP > item.price ? Math.round((1 - item.price / oldP) * 100) : 0;
              var typeLabel = item.type === 'course' ? 'Course' : item.type === 'bundle' ? 'Bundle' : item.type === 'workshop' ? 'Workshop' : 'E-Book';
            %>
            <div class="relative rounded-2xl border border-white/10 bg-[#0a1428] p-4 md:p-5">
              <form action="/cart/remove" method="post" class="absolute right-3 top-3">
                <input type="hidden" name="index" value="<%= index %>" />
                <button type="submit" class="flex items-center gap-1 rounded-lg bg-red-500/10 px-3 py-1.5 text-xs font-semibold text-red-400 hover:bg-red-500/20">
                  <svg class="h-3.5 w-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/></svg>
                  Remove
                </button>
              </form>
              <div class="flex gap-4 pr-20">
                <img src="<%= item.image %>" alt="" class="h-24 w-36 shrink-0 rounded-xl object-cover" />
                <div class="min-w-0 flex-1">
                  <span class="rounded-md bg-sky/20 px-2 py-0.5 text-xs font-semibold text-sky"><%= typeLabel %></span>
                  <h2 class="mt-1.5 font-bold text-white line-clamp-2"><%= item.title %></h2>
                  <div class="mt-2 flex flex-wrap items-baseline gap-2">
                    <span class="text-lg font-bold text-[#00a2ff]">৳<%= item.price.toLocaleString("bn-BD") %></span>
                    <% if (oldP > item.price) { %>
                      <span class="text-sm text-slate-500 line-through">৳<%= oldP.toLocaleString("bn-BD") %></span>
                      <span class="rounded-full bg-emerald-500/20 px-2 py-0.5 text-xs font-semibold text-emerald-300"><%= discPct %>% ছাড়</span>
                    <% } %>
                  </div>
                </div>
                <div class="shrink-0 text-right">
                  <p class="text-lg font-bold text-white">৳<%= lineTotal.toLocaleString("bn-BD") %></p>
                  <p class="text-xs text-slate-500 mt-1">Qty: <%= qty %></p>
                </div>
              </div>
            </div>
          <% }); %>

          <div class="flex justify-end">
            <form action="/cart/clear" method="post" onsubmit="return confirm('কার্ট খালি করবেন?');">
              <button type="submit" class="flex items-center gap-2 rounded-xl border border-red-500/40 px-4 py-2 text-sm text-red-400 hover:bg-red-500/10">
                <svg class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16"/></svg>
                Clear Cart
              </button>
            </form>
          </div>
        </div>

        <!-- Order Summary + Payment -->
        <aside class="space-y-4 lg:sticky lg:top-24 lg:self-start">

          <!-- Order Summary -->
          <div class="rounded-2xl border border-white/10 bg-[#0a1428] p-5">
            <h3 class="font-semibold text-white mb-4">📋 Order Summary</h3>
            <dl class="space-y-2 text-sm">
              <div class="flex justify-between text-slate-400">
                <dt>Subtotal (<%= qtyTotal %> items)</dt>
                <dd class="text-white">৳ <%= subtotalOld.toLocaleString("bn-BD") %></dd>
              </div>
              <div class="flex justify-between text-slate-400">
                <dt>Discount</dt>
                <dd class="text-emerald-400">− ৳ <%= discountTotal.toLocaleString("bn-BD") %></dd>
              </div>
              <div class="flex justify-between border-t border-white/10 pt-3 text-base font-bold">
                <dt class="text-white">Total</dt>
                <dd class="text-[#00a2ff]">৳ <%= total.toLocaleString("bn-BD") %></dd>
              </div>
            </dl>
          </div>

          <!-- EPS Payment -->
          <div class="rounded-2xl border border-[#00a2ff]/30 bg-[#0a1428] p-5">
            <h3 class="font-semibold text-white mb-4">💳 Payment</h3>

            <!-- EPS option -->
            <div class="rounded-xl border border-[#00a2ff]/40 bg-[#00a2ff]/5 p-4 mb-4">
              <div class="flex items-center gap-3">
                <div class="flex h-10 w-10 items-center justify-center rounded-full bg-[#00a2ff]/20 text-xs font-bold text-[#00a2ff]">EPS</div>
                <div>
                  <p class="font-medium text-white text-sm">EPS Payment Gateway</p>
                  <p class="text-xs text-slate-400">bKash · Nagad · Rocket · Visa · Mastercard</p>
                </div>
              </div>
            </div>

            <!-- Phone number -->
            <div class="mb-4">
              <label class="block text-xs text-slate-400 mb-1.5">আপনার ফোন নম্বর *</label>
              <input id="cartPhone" type="tel" placeholder="01XXXXXXXXX"
                class="w-full rounded-xl border border-white/10 bg-[#000b1a] px-4 py-3 text-sm text-white placeholder:text-slate-500 focus:border-[#00a2ff] focus:outline-none"/>
            </div>

            <!-- Error/success msg -->
            <div id="cartMsg" class="hidden mb-3 rounded-xl px-4 py-3 text-sm font-medium"></div>

            <!-- Terms -->
            <label class="flex cursor-pointer items-start gap-2 text-xs text-slate-400 mb-4">
              <input id="cartAgree" type="checkbox" checked class="mt-0.5 accent-sky shrink-0"/>
              <span>Terms &amp; Conditions, Privacy Policy এবং Refund Policy তে সম্মত আছি।</span>
            </label>

            <% if (typeof firstCheckoutTarget !== 'undefined' && firstCheckoutTarget) { %>
              <button id="cartPayBtn" onclick="handleCartPayment()" type="button"
                class="flex w-full items-center justify-center gap-2 rounded-xl bg-gradient-to-r from-[#00a2ff] to-blue-600 py-3.5 text-base font-bold text-white shadow-lg hover:opacity-90 disabled:opacity-50">
                <svg class="h-5 w-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z"/></svg>
                Proceed To Payment
              </button>
              <% if (showCheckoutNote) { %>
                <p class="mt-2 text-center text-xs text-slate-500">কার্টের প্রথম আইটেম checkout হবে। একাধিক আইটেম আলাদা অর্ডার করুন।</p>
              <% } %>
            <% } else { %>
              <button disabled class="w-full cursor-not-allowed rounded-xl bg-slate-700 py-3.5 text-base font-bold text-slate-400">Proceed To Payment</button>
            <% } %>
          </div>

          <!-- Payment logos -->
          <div class="rounded-2xl border border-white/10 bg-[#0a1428] p-4">
            <p class="text-xs text-slate-500 mb-3 text-center">Secured by EPS Payment Gateway</p>
            <div class="flex flex-wrap justify-center gap-2">
              <span class="rounded-lg bg-[#e2136e] px-3 py-1 text-xs font-bold text-white">bKash</span>
              <span class="rounded-lg bg-[#F6821F] px-3 py-1 text-xs font-bold text-white">Nagad</span>
              <span class="rounded-lg bg-[#8B2FC9] px-3 py-1 text-xs font-bold text-white">Rocket</span>
              <span class="rounded-lg bg-[#1A1F71] px-3 py-1 text-xs font-bold text-white">VISA</span>
              <span class="rounded-lg bg-[#EB001B] px-3 py-1 text-xs font-bold text-white">MC</span>
            </div>
          </div>

        </aside>
      </div>
    <% } %>
  </main>
  <%- include('../partials/footer') %>
  <%- include('../partials/scripts') %>

  <script>
    var CART_TYPE = '<%= typeof firstCheckoutTarget !== "undefined" && firstCheckoutTarget ? firstCheckoutTarget.type : "" %>';
    var CART_SLUG = '<%= typeof firstCheckoutTarget !== "undefined" && firstCheckoutTarget ? firstCheckoutTarget.slug : "" %>';
    var CART_TOTAL = <%= total %>;

    function showCartMsg(text, isError) {
      var el = document.getElementById('cartMsg');
      el.textContent = text;
      el.className = 'mb-3 rounded-xl px-4 py-3 text-sm font-medium ' +
        (isError ? 'bg-red-500/20 text-red-400 border border-red-500/30'
                 : 'bg-green-500/20 text-green-400 border border-green-500/30');
      el.classList.remove('hidden');
    }

    async function handleCartPayment() {
      var token = localStorage.getItem('cnc_token');
      if (!token) {
        showCartMsg('Payment করতে আগে Login করুন।', true);
        setTimeout(function() { window.location.href = '/login'; }, 1500);
        return;
      }
      if (!document.getElementById('cartAgree').checked) {
        showCartMsg('Terms & Conditions এ সম্মত হতে হবে।', true);
        return;
      }
      var phone = document.getElementById('cartPhone').value.trim();
      if (!phone || phone.length < 11) {
        showCartMsg('সঠিক ফোন নম্বর দিন।', true);
        return;
      }

      var btn = document.getElementById('cartPayBtn');
      btn.disabled = true;
      btn.textContent = 'Processing…';

      try {
        // Create order
        var orderRes = await fetch('/api/orders', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json', 'Authorization': 'Bearer ' + token },
          credentials: 'include',
          body: JSON.stringify({
            items: [{ productType: CART_TYPE.toUpperCase(), productSlug: CART_SLUG, price: CART_TOTAL }]
          }),
        });
        var order = await orderRes.json();
        if (!orderRes.ok) {
          showCartMsg(order.error || 'Order তৈরি করতে সমস্যা।', true);
          btn.disabled = false; btn.textContent = 'Proceed To Payment'; return;
        }

        // Initiate EPS payment
        var epsRes = await fetch('/api/orders/' + order.id + '/initiate-eps', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json', 'Authorization': 'Bearer ' + token },
          credentials: 'include',
          body: JSON.stringify({ phone: phone }),
        });
        var epsData = await epsRes.json();
        if (!epsRes.ok) {
          showCartMsg(epsData.error || 'Payment initiation failed।', true);
          btn.disabled = false; btn.textContent = 'Proceed To Payment'; return;
        }

        showCartMsg('EPS payment page এ redirect হচ্ছে…', false);
        window.location.href = epsData.paymentUrl;

      } catch (err) {
        showCartMsg('Network error। আবার চেষ্টা করুন।', true);
        btn.disabled = false; btn.textContent = 'Proceed To Payment';
      }
    }
  </script>
</body>
</html>

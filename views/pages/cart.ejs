<!DOCTYPE html>
<html lang="bn" class="scroll-smooth">
<head>
  <%- include('../partials/head') %>
</head>
<body class="min-h-screen bg-[#001529] font-display text-slate-200 antialiased">
  <%- include('../partials/navbar') %>
  <main class="mx-auto max-w-7xl px-4 py-8 md:px-6">
    <nav class="mb-6 text-sm text-slate-500">
      <span class="mr-1">🏠</span>
      <a href="/" class="hover:text-sky">Home</a>
      <span class="mx-2">›</span>
      <span class="text-slate-300">Cart</span>
    </nav>
    <h1 class="text-2xl font-bold text-white md:text-3xl">Your Cart (<%= lineCount %> item<%= lineCount === 1 ? '' : 's' %>)</h1>

    <% if (!cart.length) { %>
      <div class="mt-10 rounded-2xl border border-white/10 bg-[#0a192f] p-12 text-center text-slate-400">
        কার্ট খালি। <a href="/courses" class="text-sky hover:underline">কোর্স ব্রাউজ করুন</a>
      </div>
    <% } else { %>
      <div class="mt-8 grid gap-8 lg:grid-cols-[1fr_360px]">
        <div>
          <% cart.forEach(function (item, index) { %>
            <% 
              var qty = item.qty || 1;
              var oldP = item.oldPrice != null ? item.oldPrice : item.price;
              var lineTotal = item.price * qty;
              var discPct = oldP > item.price ? Math.round((1 - item.price / oldP) * 100) : 0;
              var typeLabel = item.type === 'course' ? 'Course' : item.type === 'bundle' ? 'Bundle' : item.type === 'workshop' ? 'Workshop' : 'E-Book';
            %>
            <div class="relative mb-4 rounded-2xl border border-white/10 bg-[#0a192f] p-4 md:p-5">
              <form action="/cart/remove" method="post" class="absolute right-3 top-3">
                <input type="hidden" name="index" value="<%= index %>" />
                <button type="submit" class="inline-flex items-center gap-2 rounded-lg bg-red-500/10 px-3 py-2 text-xs font-semibold text-red-300 hover:bg-red-500/15" title="Remove" aria-label="Remove item">
                  <svg class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16"/></svg>
                  Remove
                </button>
              </form>
              <div class="flex flex-col gap-4 sm:flex-row sm:items-start pr-10">
                <img src="<%= item.image %>" alt="" class="h-28 w-40 shrink-0 rounded-xl object-cover sm:h-32 sm:w-44" width="176" height="128" />
                <div class="min-w-0 flex-1">
                  <span class="inline-block rounded-md bg-sky/20 px-2 py-0.5 text-xs font-semibold text-sky"><%= typeLabel %></span>
                  <h2 class="mt-2 text-lg font-bold text-white"><%= item.title %></h2>
                  <div class="mt-2 flex flex-wrap items-baseline gap-2">
                    <span class="text-xl font-bold text-sky">৳<%= item.price.toLocaleString("bn-BD") %></span>
                    <% if (oldP > item.price) { %>
                      <span class="text-sm text-slate-500 line-through">৳<%= oldP.toLocaleString("bn-BD") %></span>
                      <span class="rounded-full bg-emerald-500/20 px-2 py-0.5 text-xs font-semibold text-emerald-300"><%= discPct %>% ছাড়</span>
                    <% } %>
                  </div>
                  <p class="mt-2 text-sm text-slate-500">Qty: <%= qty %></p>
                </div>
                <div class="text-right sm:pt-8">
                  <p class="text-lg font-bold text-white">৳<%= lineTotal.toLocaleString("bn-BD") %></p>
                </div>
              </div>
            </div>
          <% }); %>
          <div class="flex justify-end">
            <form action="/cart/clear" method="post" onsubmit="return confirm('কার্ট খালি করবেন?');">
              <button type="submit" class="inline-flex items-center gap-2 rounded-xl border border-red-500/60 bg-transparent px-4 py-2 text-sm font-medium text-red-400 transition hover:bg-red-500/10">
                <svg class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16"/></svg>
                Clear Cart
              </button>
            </form>
          </div>
        </div>

        <aside class="space-y-4 lg:sticky lg:top-24 lg:self-start">
          <button type="button" class="flex w-full items-center justify-between rounded-xl border border-white/10 bg-[#0a192f] px-4 py-3 text-left text-sm text-slate-300 hover:bg-white/5">
            <span class="flex items-center gap-2">🏷️ Promo Code?</span>
            <svg class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/></svg>
          </button>
          <div class="rounded-2xl border border-white/10 bg-[#0a192f] p-5">
            <h3 class="flex items-center gap-2 font-semibold text-white">💳 Payment Method</h3>
            <div class="mt-4 space-y-3">
              <label class="flex cursor-pointer items-center gap-3 rounded-xl border border-white/10 bg-night/40 p-3 has-[:checked]:border-sky/50">
                <input type="radio" name="cartpay" value="ssl" class="text-sky" />
                <span class="text-sm text-slate-300">Nagad / Rocket / Visa / Master Card</span>
              </label>
              <label class="flex cursor-pointer items-center gap-3 rounded-xl border-2 border-pink-500/50 bg-pink-950/20 p-3">
                <input type="radio" name="cartpay" value="bkash" checked class="text-pink-500" />
                <span class="text-sm font-medium text-white">bKash</span>
              </label>
            </div>
          </div>
          <div class="rounded-2xl border border-white/10 bg-[#0a192f] p-5">
            <h3 class="flex items-center gap-2 font-semibold text-white">📋 Order Summary</h3>
            <dl class="mt-4 space-y-2 text-sm">
              <div class="flex justify-between text-slate-400">
                <dt>Subtotal (<%= qtyTotal %> items)</dt>
                <dd class="text-white">৳ <%= subtotalOld.toLocaleString("bn-BD") %></dd>
              </div>
              <div class="flex justify-between text-slate-400">
                <dt>Product Discount</dt>
                <dd class="text-emerald-400">− ৳ <%= discountTotal.toLocaleString("bn-BD") %></dd>
              </div>
              <div class="flex justify-between border-t border-white/10 pt-3 text-base font-bold">
                <dt class="text-white">Total Amount</dt>
                <dd class="text-sky">৳ <%= total.toLocaleString("bn-BD") %></dd>
              </div>
            </dl>
            <label class="mt-4 flex cursor-pointer items-start gap-3 text-xs leading-relaxed text-slate-400">
              <input type="checkbox" checked class="mt-0.5 rounded border-white/20 bg-night text-sky" />
              <span>I Have Read And Agree To The Terms &amp; Conditions, Privacy Policy, And Refund Policy.</span>
            </label>
            <% if (typeof firstCheckoutTarget !== 'undefined' && firstCheckoutTarget) { %>
              <a href="/checkout?type=<%= encodeURIComponent(firstCheckoutTarget.type) %>&slug=<%= encodeURIComponent(firstCheckoutTarget.slug) %>" class="mt-4 flex w-full items-center justify-center gap-2 rounded-xl bg-[#007bff] py-3.5 text-base font-bold text-white shadow-lg hover:bg-[#0066dd]">
                <svg class="h-5 w-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z"/></svg>
                Proceed To Payment
              </a>
              <% if (typeof showCheckoutNote !== 'undefined' && showCheckoutNote) { %>
                <p class="mt-2 text-center text-[10px] text-slate-500">চেকআউট: কার্টের প্রথম আইটেম। একাধিক আইটেম থাকলে আলাদা অর্ডার করুন।</p>
              <% } %>
            <% } else { %>
              <button type="button" disabled class="mt-4 w-full cursor-not-allowed rounded-xl bg-slate-700 py-3.5 text-base font-bold text-slate-400">Proceed To Payment</button>
              <p class="mt-2 text-center text-xs text-slate-500">চেকআউটের জন্য কার্টে কমপক্ষে একটি আইটেম থাকতে হবে।</p>
            <% } %>
          </div>
        </aside>
      </div>
    <% } %>
  </main>
  <%- include('../partials/footer') %>
  <%- include('../partials/scripts') %>
</body>
</html>

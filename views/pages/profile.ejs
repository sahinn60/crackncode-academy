<!DOCTYPE html>
<html lang="bn" class="scroll-smooth">
<head>
  <%- include('../partials/head') %>
</head>
<body class="min-h-screen bg-[#000b1a] font-display text-slate-200 antialiased">
  <%- include('../partials/navbar') %>

  <main class="mx-auto max-w-4xl px-4 py-10 md:px-6">

    <!-- Breadcrumb -->
    <nav class="mb-6 text-sm text-slate-500">
      <a href="/" class="hover:text-sky">হোম</a>
      <span class="mx-2">›</span>
      <span class="text-slate-300">My Profile</span>
    </nav>

    <!-- Profile header card -->
    <div class="relative overflow-hidden rounded-2xl border border-white/10 bg-[#0a1428] p-6 md:p-8">
      <div class="absolute inset-0 bg-gradient-to-br from-[#00a2ff]/10 via-transparent to-[#ff6600]/10 pointer-events-none"></div>
      <div class="relative flex flex-col items-center gap-5 sm:flex-row sm:items-start">
        <!-- Avatar -->
        <div class="flex h-20 w-20 shrink-0 items-center justify-center rounded-full bg-gradient-to-br from-[#00a2ff] to-[#ff6600] text-2xl font-bold text-white shadow-lg">
          <%= user.name.slice(0,2).toUpperCase() %>
        </div>
        <!-- Info -->
        <div class="flex-1 text-center sm:text-left">
          <div class="flex flex-wrap items-center justify-center gap-2 sm:justify-start">
            <h1 class="text-2xl font-bold text-white"><%= user.name %></h1>
            <% if (user.role === 'ADMIN') { %>
              <span class="rounded-full bg-cyan-500/20 px-2.5 py-0.5 text-xs font-semibold text-cyan-400">Admin</span>
            <% } else { %>
              <span class="rounded-full bg-blue-500/20 px-2.5 py-0.5 text-xs font-semibold text-blue-400">Student</span>
            <% } %>
          </div>
          <p class="mt-1 text-sm text-slate-400"><%= user.email %></p>
          <p class="mt-1 text-xs text-slate-500">Member since <%= new Date(user.createdAt).toLocaleDateString('en-GB', { day:'numeric', month:'long', year:'numeric' }) %></p>
        </div>
        <!-- Stats -->
        <div class="flex gap-6 rounded-xl border border-white/10 bg-white/5 px-6 py-4 text-center">
          <div>
            <p class="text-xl font-bold text-white"><%= enrollments.length %></p>
            <p class="text-xs text-slate-400">Courses</p>
          </div>
          <div class="border-l border-white/10"></div>
          <div>
            <p class="text-xl font-bold text-white"><%= orders.length %></p>
            <p class="text-xs text-slate-400">Orders</p>
          </div>
        </div>
      </div>
    </div>

    <!-- Tabs -->
    <div class="mt-8 flex gap-1 rounded-xl border border-white/10 bg-[#0a1428] p-1 w-fit">
      <button onclick="switchTab('courses')" id="tab-courses"
        class="tab-btn rounded-lg bg-gradient-to-r from-cyan-500 to-blue-600 px-5 py-2 text-sm font-semibold text-white">
        My Courses
      </button>
      <button onclick="switchTab('orders')" id="tab-orders"
        class="tab-btn rounded-lg px-5 py-2 text-sm text-slate-300 hover:bg-white/5">
        My Orders
      </button>
      <button onclick="switchTab('settings')" id="tab-settings"
        class="tab-btn rounded-lg px-5 py-2 text-sm text-slate-300 hover:bg-white/5">
        Settings
      </button>
    </div>

    <!-- My Courses tab -->
    <div id="panel-courses" class="mt-6">
      <% if (enrollments.length === 0) { %>
        <div class="flex flex-col items-center justify-center rounded-2xl border border-white/10 bg-[#0a1428] py-16 text-center">
          <svg class="h-12 w-12 text-slate-600" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M12 6.253v13m0-13C10.832 5.477 9.246 5 7.5 5S4.168 5.477 3 6.253v13C4.168 18.477 5.754 18 7.5 18s3.332.477 4.5 1.253m0-13C13.168 5.477 14.754 5 16.5 5c1.747 0 3.332.477 4.5 1.253v13C19.832 18.477 18.247 18 16.5 18c-1.746 0-3.332.477-4.5 1.253"/></svg>
          <p class="mt-4 text-slate-400">No courses enrolled yet.</p>
          <a href="/courses" class="mt-4 rounded-full bg-gradient-to-r from-cyan-500 to-blue-600 px-5 py-2 text-sm font-semibold text-white">Browse Courses</a>
        </div>
      <% } else { %>
        <div class="grid gap-4 sm:grid-cols-2">
          <% enrollments.forEach(function(e) { %>
            <a href="/courses/<%= e.course.slug %>"
              class="flex gap-4 rounded-2xl border border-white/10 bg-[#0a1428] p-4 transition hover:border-[#00a2ff]/40 hover:bg-white/5">
              <img src="<%= e.course.imageUrl %>" alt="" class="h-16 w-24 shrink-0 rounded-lg object-cover" />
              <div class="min-w-0">
                <p class="truncate font-semibold text-white"><%= e.course.title %></p>
                <p class="mt-1 text-xs text-slate-400"><%= e.course.category %></p>
                <p class="mt-2 text-xs text-slate-500">Enrolled <%= new Date(e.enrolledAt).toLocaleDateString('en-GB') %></p>
              </div>
            </a>
          <% }) %>
        </div>
      <% } %>
    </div>

    <!-- My Orders tab -->
    <div id="panel-orders" class="mt-6 hidden">
      <% if (orders.length === 0) { %>
        <div class="flex flex-col items-center justify-center rounded-2xl border border-white/10 bg-[#0a1428] py-16 text-center">
          <svg class="h-12 w-12 text-slate-600" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2"/></svg>
          <p class="mt-4 text-slate-400">No orders yet.</p>
        </div>
      <% } else { %>
        <div class="space-y-3">
          <% orders.forEach(function(order) { %>
            <div class="rounded-2xl border border-white/10 bg-[#0a1428] p-5">
              <div class="flex flex-wrap items-center justify-between gap-3">
                <div>
                  <p class="text-xs text-slate-500">Order ID</p>
                  <p class="font-mono text-sm text-white"><%= order.id.slice(0,16) %>…</p>
                </div>
                <div>
                  <p class="text-xs text-slate-500">Date</p>
                  <p class="text-sm text-white"><%= new Date(order.createdAt).toLocaleDateString('en-GB') %></p>
                </div>
                <div>
                  <p class="text-xs text-slate-500">Total</p>
                  <p class="text-sm font-bold text-white">৳ <%= order.totalPrice.toLocaleString() %></p>
                </div>
                <span class="rounded-full px-3 py-1 text-xs font-semibold
                  <%= order.status === 'PAID' ? 'bg-emerald-500/20 text-emerald-400' :
                      order.status === 'PENDING' ? 'bg-amber-500/20 text-amber-400' :
                      order.status === 'REFUNDED' ? 'bg-blue-500/20 text-blue-400' :
                      'bg-red-500/20 text-red-400' %>">
                  <%= order.status %>
                </span>
              </div>
              <% if (order.items && order.items.length > 0) { %>
                <ul class="mt-3 space-y-1 border-t border-white/10 pt-3">
                  <% order.items.forEach(function(item) { %>
                    <li class="flex justify-between text-xs text-slate-400">
                      <span class="truncate"><%= item.productSlug %></span>
                      <span class="ml-4 shrink-0 text-white">৳ <%= item.price.toLocaleString() %></span>
                    </li>
                  <% }) %>
                </ul>
              <% } %>
            </div>
          <% }) %>
        </div>
      <% } %>
    </div>

    <!-- Settings tab -->
    <div id="panel-settings" class="mt-6 hidden">
      <div class="rounded-2xl border border-white/10 bg-[#0a1428] p-6 md:p-8">
        <h2 class="text-lg font-semibold text-white">Account Settings</h2>
        <div id="settingsMsg" class="hidden mt-4 rounded-lg px-4 py-3 text-sm font-medium"></div>
        <form id="settingsForm" class="mt-6 space-y-4">
          <div>
            <label class="text-sm text-slate-300">Full Name</label>
            <input id="settingsName" type="text" value="<%= user.name %>"
              class="mt-1 w-full rounded-xl border border-white/10 bg-[#000b1a] px-4 py-3 text-sm text-white focus:border-sky focus:outline-none" />
          </div>
          <div>
            <label class="text-sm text-slate-300">Email</label>
            <input type="email" value="<%= user.email %>" disabled
              class="mt-1 w-full rounded-xl border border-white/10 bg-white/5 px-4 py-3 text-sm text-slate-500 cursor-not-allowed" />
            <p class="mt-1 text-xs text-slate-500">Email cannot be changed.</p>
          </div>
          <div class="border-t border-white/10 pt-4">
            <label class="text-sm text-slate-300">New Password <span class="text-slate-500">(leave blank to keep current)</span></label>
            <input id="settingsPassword" type="password" placeholder="••••••••"
              class="mt-1 w-full rounded-xl border border-white/10 bg-[#000b1a] px-4 py-3 text-sm text-white focus:border-sky focus:outline-none" />
          </div>
          <button type="submit"
            class="rounded-xl bg-gradient-to-r from-cyan-500 to-blue-600 px-6 py-2.5 text-sm font-semibold text-white hover:opacity-90">
            Save Changes
          </button>
        </form>
      </div>
    </div>

  </main>

  <%- include('../partials/footer') %>
  <%- include('../partials/scripts') %>

  <script>
    // Tab switching
    function switchTab(name) {
      ["courses", "orders", "settings"].forEach(function(t) {
        document.getElementById("panel-" + t).classList.add("hidden");
        var btn = document.getElementById("tab-" + t);
        btn.className = "tab-btn rounded-lg px-5 py-2 text-sm text-slate-300 hover:bg-white/5";
      });
      document.getElementById("panel-" + name).classList.remove("hidden");
      document.getElementById("tab-" + name).className =
        "tab-btn rounded-lg bg-gradient-to-r from-cyan-500 to-blue-600 px-5 py-2 text-sm font-semibold text-white";
    }

    // Settings form
    document.getElementById("settingsForm").addEventListener("submit", async function(e) {
      e.preventDefault();
      var name     = document.getElementById("settingsName").value.trim();
      var password = document.getElementById("settingsPassword").value;
      var token    = localStorage.getItem("cnc_token");
      var msg      = document.getElementById("settingsMsg");

      if (!name) { showSettingsMsg("Name cannot be empty.", true); return; }

      var body = { name };
      if (password) {
        if (password.length < 6) { showSettingsMsg("Password must be at least 6 characters.", true); return; }
        body.password = password;
      }

      try {
        var res = await fetch("/api/auth/profile", {
          method: "PATCH",
          headers: { "Content-Type": "application/json", "Authorization": "Bearer " + token },
          body: JSON.stringify(body),
        });
        var data = await res.json();
        if (!res.ok) return showSettingsMsg(data.error || "Update failed.", true);
        showSettingsMsg("Profile updated successfully!", false);
        // update localStorage user
        var u = JSON.parse(localStorage.getItem("cnc_user") || "{}");
        u.name = data.name;
        localStorage.setItem("cnc_user", JSON.stringify(u));
      } catch(err) {
        showSettingsMsg("Network error.", true);
      }
    });

    function showSettingsMsg(text, isError) {
      var el = document.getElementById("settingsMsg");
      el.textContent = text;
      el.className = "mt-4 rounded-lg px-4 py-3 text-sm font-medium " +
        (isError ? "bg-red-500/20 text-red-400 border border-red-500/30"
                 : "bg-green-500/20 text-green-400 border border-green-500/30");
      el.classList.remove("hidden");
    }
  </script>
</body>
</html>

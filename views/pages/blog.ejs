<!DOCTYPE html>
<html lang="bn" class="scroll-smooth">
<head>
  <%- include('../partials/head') %>
</head>
<body class="min-h-screen bg-night font-display text-slate-200 antialiased">
  <%- include('../partials/navbar') %>
  <main class="mx-auto max-w-7xl px-4 py-8 md:px-6">
    <nav class="mb-6 text-sm text-slate-500">
      <span class="mr-1">🏠</span>
      <a href="/" class="hover:text-sky">Home</a>
      <span class="mx-2">›</span>
      <span class="text-slate-300">Blogs</span>
    </nav>
    <h1 class="mb-10 text-center text-3xl font-bold text-white md:text-4xl">Latest Blogs</h1>
    <div class="grid gap-6 sm:grid-cols-2 lg:grid-cols-4">
      <% blogs.forEach(function (post) { %>
        <article class="flex flex-col overflow-hidden rounded-2xl border border-white/10 bg-card shadow-lg transition hover:border-sky/40">
          <div class="aspect-video overflow-hidden">
            <a href="/blog/<%= post.slug %>">
              <img src="<%= post.image %>" alt="" class="h-full w-full object-cover transition hover:scale-105 duration-300" loading="lazy" width="640" height="360" />
            </a>
          </div>
          <div class="flex flex-1 flex-col p-5">
            <time class="text-xs text-slate-500"><%= post.date %></time>
            <a href="/blog/<%= post.slug %>">
              <h2 class="mt-2 line-clamp-2 text-lg font-bold text-white hover:text-sky"><%= post.title %></h2>
            </a>
            <p class="mt-2 line-clamp-3 flex-1 text-sm text-slate-400"><%= post.excerpt %></p>
            <a href="/blog/<%= post.slug %>" class="mt-4 inline-flex w-fit items-center gap-1 rounded-lg border border-white/15 bg-night/60 px-3 py-2 text-xs font-medium text-white hover:border-sky/40">
              Read More
              <svg class="h-3 w-3" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg>
            </a>
          </div>
        </article>
      <% }); %>
    </div>
    <div class="mt-12 rounded-2xl border border-white/10 bg-card/80 p-6">
      <div class="flex flex-col gap-4 lg:flex-row lg:items-center lg:justify-between">
        <p class="text-sm font-semibold text-white">Filter</p>
        <p class="text-center text-sm text-slate-400"><%= count %> Blogs Found</p>
        <select class="rounded-xl border border-white/10 bg-[#0a1428] px-4 py-2 text-sm text-white lg:w-48">
          <option>Default Sorting</option>
        </select>
      </div>
      <div class="mt-4 flex flex-wrap gap-4 border-t border-white/10 pt-4">
        <div>
          <p class="mb-2 text-xs font-semibold uppercase text-slate-500">Category</p>
          <label class="flex cursor-pointer items-center gap-2 text-sm text-slate-300"><input type="checkbox" checked class="rounded border-white/20 bg-night text-sky" /> All</label>
        </div>
      </div>
    </div>
  </main>
  <%- include('../partials/footer') %>
  <button type="button" id="toTop" class="fixed bottom-6 right-6 z-50 flex h-12 w-12 items-center justify-center rounded-full bg-sky text-night opacity-0 pointer-events-none transition-opacity" aria-label="উপরে">
    <svg class="h-5 w-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 10l7-7m0 0l7 7m-7-7v18"/></svg>
  </button>
  <%- include('../partials/scripts') %>
</body>
</html>

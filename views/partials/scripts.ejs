<script>
  (function () {
    function updateCartBadge(count) {
      var badge = document.getElementById("cartBadge");
      if (!badge) return;
      var n = Number(count || 0);
      if (n > 0) {
        badge.textContent = String(n);
        badge.classList.remove("hidden");
        badge.classList.add("flex");
      } else {
        badge.textContent = "";
        badge.classList.add("hidden");
        badge.classList.remove("flex");
      }
    }

    // Initialize badge from server-rendered locals (if any)
    try {
      var initial = <%- typeof cartCount !== 'undefined' ? JSON.stringify(cartCount) : "0" %>;
      updateCartBadge(initial);
    } catch (_e) {}

    // AJAX add-to-cart: prevent page jump to top
    document.addEventListener("submit", async function (e) {
      var form = e.target;
      if (!form || form.tagName !== "FORM") return;
      if (!form.hasAttribute("data-ajax-cart")) return;

      e.preventDefault();
      var btn = form.querySelector('button[type="submit"]');
      var oldText = btn ? btn.textContent : "";
      if (btn) {
        btn.disabled = true;
        btn.style.opacity = "0.75";
      }

      try {
        var fd = new FormData(form);
        // Tell server to return JSON, not a redirect
        fd.append("ajax", "1");
        var res = await fetch(form.action, {
          method: "POST",
          body: new URLSearchParams(fd),
          headers: { "Content-Type": "application/x-www-form-urlencoded;charset=UTF-8" },
        });
        if (!res.ok) throw new Error("Add to cart failed");

        var data = await res.json();
        if (data && typeof data.count !== "undefined") updateCartBadge(data.count);
        else {
          // fallback refresh count
          var cRes = await fetch("/cart/count");
          if (cRes.ok) {
            var cData = await cRes.json();
            updateCartBadge(cData.count);
          }
        }
      } catch (_err) {
        // fallback to normal submit if fetch fails
        form.removeAttribute("data-ajax-cart");
        form.submit();
      } finally {
        if (btn) {
          btn.disabled = false;
          btn.style.opacity = "";
          btn.textContent = oldText;
        }
      }
    });
  })();
</script>

<% 
  function navClass(key) {
    return activeNav === key
      ? 'rounded-full bg-[#00a2ff] px-4 py-2 text-sm font-medium text-white'
      : 'rounded-full px-4 py-2 text-sm text-slate-300 transition hover:bg-white/5 hover:text-white';
  }
%>
<header class="sticky top-0 z-50 border-b border-white/5 bg-[#001529]/95 backdrop-blur-md">
  <div class="mx-auto flex max-w-7xl flex-wrap items-center justify-between gap-4 px-4 py-3 md:px-6">
    <a href="/" class="flex items-center gap-2">
      <img src="/images/logo.png" alt="CrackNcode Academy" class="h-9 w-auto max-h-10 object-contain object-left md:h-10" width="180" height="40" />
    </a>

    <div class="order-3 flex w-full max-w-md flex-1 items-center md:order-none md:w-auto">
      <form action="/search" method="get" class="flex w-full overflow-hidden rounded-full border border-white/10 bg-[#0a1428]">
        <input type="search" name="q" value="<%= typeof searchQuery !== 'undefined' ? searchQuery : '' %>" placeholder="Search..." class="w-full bg-transparent px-4 py-2.5 text-sm text-white placeholder:text-slate-500 focus:outline-none" />
        <button type="submit" class="flex items-center justify-center rounded-full bg-[#007bff] p-2.5 m-1 text-white shadow-md hover:bg-[#0066dd]" aria-label="Search">
          <svg class="h-5 w-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"/></svg>
        </button>
      </form>
    </div>

    <nav class="hidden items-center gap-1 rounded-full border border-white/10 bg-[#0a1428]/80 p-1 lg:flex" aria-label="Main">
      <a href="/" class="<%= navClass('home') %>">হোম</a>
      <a href="/courses" class="<%= navClass('courses') %>">কোর্স</a>
      <a href="/bundles" class="<%= navClass('bundles') %>">বান্ডেল</a>
      <a href="/workshops" class="<%= navClass('workshops') %>">ওয়ার্কশপ</a>
      <a href="/ebooks" class="<%= navClass('ebooks') %>">ই-বুক</a>
      <a href="/blog" class="<%= navClass('blog') %>">ব্লগ</a>
    </nav>

    <div class="flex items-center gap-2">
      <a href="/cart" class="relative flex h-10 w-10 items-center justify-center rounded-full border <%= activeNav === 'cart' ? 'border-sky/50 bg-sky/10' : 'border-white/10' %> bg-[#0a1428] text-slate-300 transition hover:border-[#00a2ff]/40 hover:text-white" title="কার্ট">
        <svg class="h-5 w-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 11V7a4 4 0 00-8 0v4M5 9h14l1 12H4L5 9z"/></svg>
        <span id="cartBadge" class="absolute -right-1 -top-1 hidden h-5 min-w-[1.25rem] items-center justify-center rounded-full bg-[#ff4d4f] px-1 text-[10px] font-bold text-white"></span>
      </a>
      <div class="relative hidden md:block" id="notifMenu">
        <button id="notifBtn" type="button" class="relative flex h-10 w-10 items-center justify-center rounded-full border border-white/10 bg-[#0a1428] text-slate-300 hover:bg-white/5" aria-label="Notifications">
          <svg class="h-5 w-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 17h5l-1.405-1.405A2.032 2.032 0 0118 14.158V11a6.002 6.002 0 00-4-5.659V5a2 2 0 10-4 0v.341C7.67 6.165 6 8.388 6 11v3.159c0 .538-.214 1.055-.595 1.436L4 17h5m6 0v1a3 3 0 11-6 0v-1m6 0H9"/></svg>
        </button>
        <div id="notifDropdown" class="absolute right-0 top-12 z-50 hidden w-72 overflow-hidden rounded-2xl border border-white/10 bg-[#0a1428] shadow-2xl shadow-black/50">
          <div class="border-b border-white/10 px-4 py-3">
            <p class="text-sm font-semibold text-white">Notifications</p>
          </div>
          <div class="grid place-items-center gap-2 px-6 py-8 text-center">
            <svg class="h-8 w-8 text-slate-500" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 17h5l-1.405-1.405A2.032 2.032 0 0118 14.158V11a6.002 6.002 0 00-4-5.659V5a2 2 0 10-4 0v.341C7.67 6.165 6 8.388 6 11v3.159c0 .538-.214 1.055-.595 1.436L4 17h5m6 0v1a3 3 0 11-6 0v-1m6 0H9"/></svg>
            <p class="text-sm text-slate-400">No notifications yet</p>
          </div>
        </div>
      </div>
      <button type="button" id="themeToggle" class="flex h-10 w-10 items-center justify-center rounded-full border border-white/10 bg-[#0a1428] text-slate-300 transition hover:border-[#00a2ff]/40 hover:text-white" aria-label="Toggle theme">
        <svg id="iconMoon" class="h-5 w-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M20.354 15.354A9 9 0 018.646 3.646 9.003 9.003 0 0012 21a9.003 9.003 0 008.354-5.646z"/></svg>
        <svg id="iconSun" class="hidden h-5 w-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 3v1m0 16v1m9-9h-1M4 12H3m15.364 6.364l-.707-.707M6.343 6.343l-.707-.707m12.728 0l-.707.707M6.343 17.657l-.707.707M16 12a4 4 0 11-8 0 4 4 0 018 0z"/></svg>
      </button>
      <% if (authUser) { %>
        <!-- Profile dropdown -->
        <div class="relative" id="profileMenu">
          <button id="profileBtn" type="button"
            class="flex items-center gap-2 rounded-full border border-white/10 bg-[#0a1428] pl-1 pr-3 py-1 transition hover:border-[#00a2ff]/40">
            <span class="flex h-8 w-8 items-center justify-center rounded-full bg-gradient-to-br from-[#00a2ff] to-[#ff6600] text-xs font-bold text-white">
              <%= authUser.name.slice(0,2).toUpperCase() %>
            </span>
            <span class="hidden max-w-[90px] truncate text-sm font-medium text-white sm:block"><%= authUser.name %></span>
            <svg class="h-3.5 w-3.5 text-slate-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/></svg>
          </button>

          <!-- Dropdown panel -->
          <div id="profileDropdown"
            class="absolute right-0 top-12 z-50 hidden w-60 rounded-2xl border border-white/10 bg-[#0a1428] shadow-2xl shadow-black/50">
            <!-- User info header -->
            <div class="flex items-center gap-3 border-b border-white/10 px-4 py-4">
              <span class="flex h-11 w-11 shrink-0 items-center justify-center rounded-full bg-gradient-to-br from-[#00a2ff] to-[#ff6600] text-sm font-bold text-white">
                <%= authUser.name.slice(0,2).toUpperCase() %>
              </span>
              <div class="min-w-0">
                <p class="truncate text-sm font-semibold text-white"><%= authUser.name %></p>
                <p class="truncate text-xs text-slate-400"><%= authUser.email %></p>
                <% if (authUser.role === 'ADMIN') { %>
                  <span class="mt-1 inline-block rounded-full bg-cyan-500/20 px-2 py-0.5 text-[10px] font-semibold text-cyan-400">Admin</span>
                <% } %>
              </div>
            </div>

            <!-- Menu items -->
            <ul class="px-2 py-2">
              <li>
                <a href="/profile" class="flex items-center gap-3 rounded-xl px-3 py-2.5 text-sm text-slate-300 transition hover:bg-white/5 hover:text-white">
                  <svg class="h-4 w-4 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"/></svg>
                  My Profile
                </a>
              </li>
              <li>
                <a href="/my-courses" class="flex items-center gap-3 rounded-xl px-3 py-2.5 text-sm text-slate-300 transition hover:bg-white/5 hover:text-white">
                  <svg class="h-4 w-4 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6.253v13m0-13C10.832 5.477 9.246 5 7.5 5S4.168 5.477 3 6.253v13C4.168 18.477 5.754 18 7.5 18s3.332.477 4.5 1.253m0-13C13.168 5.477 14.754 5 16.5 5c1.747 0 3.332.477 4.5 1.253v13C19.832 18.477 18.247 18 16.5 18c-1.746 0-3.332.477-4.5 1.253"/></svg>
                  My Courses
                </a>
              </li>
              <li>
                <a href="/orders" class="flex items-center gap-3 rounded-xl px-3 py-2.5 text-sm text-slate-300 transition hover:bg-white/5 hover:text-white">
                  <svg class="h-4 w-4 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2"/></svg>
                  My Orders
                </a>
              </li>
              <% if (authUser.role === 'ADMIN') { %>
              <li>
                <a href="/admin" class="flex items-center gap-3 rounded-xl px-3 py-2.5 text-sm text-cyan-400 transition hover:bg-cyan-500/10">
                  <svg class="h-4 w-4 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10.325 4.317c.426-1.756 2.924-1.756 3.35 0a1.724 1.724 0 002.573 1.066c1.543-.94 3.31.826 2.37 2.37a1.724 1.724 0 001.065 2.572c1.756.426 1.756 2.924 0 3.35a1.724 1.724 0 00-1.066 2.573c.94 1.543-.826 3.31-2.37 2.37a1.724 1.724 0 00-2.572 1.065c-.426 1.756-2.924 1.756-3.35 0a1.724 1.724 0 00-2.573-1.066c-1.543.94-3.31-.826-2.37-2.37a1.724 1.724 0 00-1.065-2.572c-1.756-.426-1.756-2.924 0-3.35a1.724 1.724 0 001.066-2.573c-.94-1.543.826-3.31 2.37-2.37.996.608 2.296.07 2.572-1.065z"/><circle cx="12" cy="12" r="3"/></svg>
                  Admin Panel
                </a>
              </li>
              <% } %>
            </ul>

            <!-- Logout -->
            <div class="border-t border-white/10 px-2 py-2">
              <form action="/logout" method="POST">
                <button type="submit" class="flex w-full items-center gap-3 rounded-xl px-3 py-2.5 text-sm text-red-400 transition hover:bg-red-500/10">
                  <svg class="h-4 w-4 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 16l4-4m0 0l-4-4m4 4H7m6 4v1a3 3 0 01-3 3H6a3 3 0 01-3-3V7a3 3 0 013-3h4a3 3 0 013 3v1"/></svg>
                  Logout
                </button>
              </form>
            </div>
          </div>
        </div>
      <% } else { %>
        <a href="/login" class="inline-flex items-center gap-2 rounded-full bg-[#ff6600] px-4 py-2.5 text-sm font-semibold text-white shadow-lg shadow-[#ff6600]/25 transition hover:bg-[#ff8533]">
          সাইন আপ / লগইন
          <svg class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14 5l7 7m0 0l-7 7m7-7H3"/></svg>
        </a>
      <% } %>
    </div>
  </div>
  <div class="flex gap-2 overflow-x-auto border-t border-white/5 px-4 py-2 lg:hidden">
    <a href="/" class="shrink-0 rounded-full <%= activeNav === 'home' ? 'bg-[#00a2ff] text-white' : 'border border-white/10 text-slate-300' %> px-3 py-1.5 text-xs">হোম</a>
    <a href="/courses" class="shrink-0 rounded-full <%= activeNav === 'courses' ? 'bg-[#00a2ff] text-white' : 'border border-white/10 text-slate-300' %> px-3 py-1.5 text-xs">কোর্স</a>
    <a href="/bundles" class="shrink-0 rounded-full <%= activeNav === 'bundles' ? 'bg-[#00a2ff] text-white' : 'border border-white/10 text-slate-300' %> px-3 py-1.5 text-xs">বান্ডেল</a>
    <a href="/workshops" class="shrink-0 rounded-full <%= activeNav === 'workshops' ? 'bg-[#00a2ff] text-white' : 'border border-white/10 text-slate-300' %> px-3 py-1.5 text-xs">ওয়ার্কশপ</a>
    <a href="/ebooks" class="shrink-0 rounded-full <%= activeNav === 'ebooks' ? 'bg-[#00a2ff] text-white' : 'border border-white/10 text-slate-300' %> px-3 py-1.5 text-xs">ই-বুক</a>
    <a href="/blog" class="shrink-0 rounded-full <%= activeNav === 'blog' ? 'bg-[#00a2ff] text-white' : 'border border-white/10 text-slate-300' %> px-3 py-1.5 text-xs">ব্লগ</a>
  </div>
</header>

<script>
  (function () {
    var btn = document.getElementById("profileBtn");
    var dropdown = document.getElementById("profileDropdown");
    if (!btn || !dropdown) return;

    btn.addEventListener("click", function (e) {
      e.stopPropagation();
      dropdown.classList.toggle("hidden");
    });

    document.addEventListener("click", function () {
      dropdown.classList.add("hidden");
    });

    dropdown.addEventListener("click", function (e) {
      e.stopPropagation();
    });
  })();

  (function () {
    var btn = document.getElementById("notifBtn");
    var dropdown = document.getElementById("notifDropdown");
    if (!btn || !dropdown) return;

    btn.addEventListener("click", function (e) {
      e.stopPropagation();
      dropdown.classList.toggle("hidden");
    });

    document.addEventListener("click", function () {
      dropdown.classList.add("hidden");
    });

    dropdown.addEventListener("click", function (e) {
      e.stopPropagation();
    });
  })();
</script>
